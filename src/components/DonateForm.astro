---
import { copy, type Lang } from '../i18n/copy';
import { getRoutes } from '../i18n/routes';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const c = copy[lang];
const f = c.form;
const routes = getRoutes(lang);
const backHref = routes.donate;

const termsDocViewUrl =
	'https://drive.google.com/file/d/1TwLR7WbaFV3MZKuyFYoRfVrjNNzsCpxs/view';
const termsDocEmbedUrl =
	'https://drive.google.com/file/d/1TwLR7WbaFV3MZKuyFYoRfVrjNNzsCpxs/preview';
---

<main class="form-page">
	<div class="container form-container">

		<!-- Back link -->
		<a class="back-link" href={backHref}>
			<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M10 3L5 8l5 5"/>
			</svg>
			{f.backBtn}
		</a>

		<!-- Page header -->
		<div class="form-header">
			<h1 class="form-title">{f.pageTitle}</h1>
			<p class="form-subtitle">{f.pageSubtitle}</p>
		</div>

		<!-- ═══ FORM ═══ -->
		<form id="support-form" method="POST" action="#" novalidate>

			<!-- ── Section 1: Contact info ── -->
			<div class="form-section">
				<div class="section-header">
					<span class="section-num" aria-hidden="true">1</span>
					<h2 class="section-title">
						{lang === 'es' ? 'Información de contacto' : 'Contact information'}
					</h2>
				</div>

				<div class="contact-grid">
					<div class="field">
						<label class="field-label" for="fullName">
							{f.labelName} <span class="req" aria-hidden="true">*</span>
						</label>
						<input
							class="field-input"
							type="text"
							id="fullName"
							name="fullName"
							placeholder={lang === 'es' ? 'Tu nombre completo' : 'Your full name'}
							required
							autocomplete="name"
						/>
					</div>

					<div class="field">
						<label class="field-label" for="phone">
							{f.labelPhone} <span class="req" aria-hidden="true">*</span>
						</label>
						<input
							class="field-input"
							type="tel"
							id="phone"
							name="phone"
							placeholder={lang === 'es' ? '+506 0000-0000' : '+1 (000) 000-0000'}
							required
							autocomplete="tel"
						/>
					</div>

					<div class="field field--full">
						<label class="field-label" for="email">
							{f.labelEmail} <span class="req" aria-hidden="true">*</span>
						</label>
						<input
							class="field-input"
							type="email"
							id="email"
							name="email"
							placeholder={lang === 'es' ? 'tu@correo.com' : 'you@email.com'}
							required
							autocomplete="email"
						/>
					</div>
				</div>
			</div>

			<!-- ── Section 2: Donation preferences ── -->
			<div class="form-section">
				<div class="section-header">
					<span class="section-num" aria-hidden="true">2</span>
					<h2 class="section-title">
						{lang === 'es' ? 'Preferencias de donación' : 'Donation preferences'}
					</h2>
				</div>

				<!-- Donation Type → pill tabs -->
				<fieldset class="field-group">
					<legend class="field-label">
						{f.labelDonationType} <span class="req" aria-hidden="true">*</span>
					</legend>
					<div class="pill-group" role="group">
						<label class="pill-label">
							<input type="radio" name="donationType" value="one-time" required />
							<span>{f.optOneTime}</span>
						</label>
						<label class="pill-label">
							<input type="radio" name="donationType" value="monthly" />
							<span>{f.optMonthly}</span>
						</label>
						<label class="pill-label">
							<input type="radio" name="donationType" value="annual" />
							<span>{f.optAnnual}</span>
						</label>
					</div>
				</fieldset>

				<!-- Donation Focus → option cards -->
				<fieldset class="field-group" style="margin-top: 22px;">
					<legend class="field-label">
						{f.labelFocus} <span class="req" aria-hidden="true">*</span>
					</legend>
					<div class="focus-grid">
						<label class="focus-card">
							<input type="radio" name="focus" value="dominical" required />
							<span class="focus-card-inner">
								<span class="focus-icon" aria-hidden="true">🏖</span>
								<span class="focus-name">{f.optDominical}</span>
							</span>
						</label>
						<label class="focus-card">
							<input type="radio" name="focus" value="hermosa" />
							<span class="focus-card-inner">
								<span class="focus-icon" aria-hidden="true">🌊</span>
								<span class="focus-name">{f.optHermosa}</span>
							</span>
						</label>
						<label class="focus-card">
							<input type="radio" name="focus" value="both" />
							<span class="focus-card-inner">
								<span class="focus-icon" aria-hidden="true">🤝</span>
								<span class="focus-name">{f.optBoth}</span>
							</span>
						</label>
					</div>
				</fieldset>
			</div>

			<!-- ── Section 3: Recognition & Communication ── -->
			<div class="form-section">
				<div class="section-header">
					<span class="section-num" aria-hidden="true">3</span>
					<h2 class="section-title">
						{lang === 'es' ? 'Reconocimiento y comunicación' : 'Recognition & communication'}
					</h2>
				</div>

				<!-- Recognition -->
				<fieldset class="field-group">
					<legend class="field-label">
						{f.labelRecognition} <span class="req" aria-hidden="true">*</span>
					</legend>
					<div class="toggle-group">
						<label class="toggle-label">
							<input type="radio" name="recognition" value="public" required />
							<span class="toggle-box">
								<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true">
									<circle cx="8" cy="6" r="3"/>
									<path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6"/>
								</svg>
								{f.optPublic}
							</span>
						</label>
						<label class="toggle-label">
							<input type="radio" name="recognition" value="anonymous" />
							<span class="toggle-box">
								<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true">
									<circle cx="8" cy="8" r="6"/>
									<path d="M8 5v4M8 12v.5"/>
								</svg>
								{f.optAnonymous}
							</span>
						</label>
					</div>
				</fieldset>

				<!-- Communication checkboxes -->
				<fieldset class="field-group" style="margin-top: 22px;">
					<legend class="field-label">
						{f.labelComms} <span class="req" aria-hidden="true">*</span>
					</legend>
					<div class="checkbox-group">
						{[
							{ value: 'impact',    label: f.optImpact },
							{ value: 'volunteer', label: f.optVolunteer },
							{ value: 'major',     label: f.optMajor },
							{ value: 'none',      label: f.optNoComms },
						].map(({ value, label }) => (
							<label class="checkbox-label">
								<input type="checkbox" name="comms" value={value} />
								<span class="checkbox-custom" aria-hidden="true">
									<svg viewBox="0 0 12 12" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M2 6l3 3 5-5"/>
									</svg>
								</span>
								{label}
							</label>
						))}
					</div>
				</fieldset>
			</div>

			<!-- ── Section 4: Notes ── -->
			<div class="form-section">
				<div class="section-header">
					<span class="section-num" aria-hidden="true">4</span>
					<h2 class="section-title">
						{lang === 'es' ? 'Notas adicionales' : 'Additional notes'}
					</h2>
				</div>

				<div class="field">
					<label class="field-label" for="notes">
						{f.labelNotes} <span class="req" aria-hidden="true">*</span>
					</label>
					<textarea
						class="field-input field-textarea"
						id="notes"
						name="notes"
						placeholder={f.notesPlaceholder}
						rows="4"
						required
					></textarea>
				</div>
			</div>

			<!-- ── Section 5: Terms ── -->
			<div class="form-section terms-section">
				<div class="section-header">
					<span class="section-num section-num--accent" aria-hidden="true">5</span>
					<h2 class="section-title">{f.termsDoc}</h2>
				</div>

				<p class="terms-hint muted">
					{lang === 'es'
						? 'Lee el documento completo antes de confirmar tu aceptación.'
						: 'Read the full document before confirming your acceptance.'}
				</p>

				<!-- Terms doc: link card + expandable embed -->
				<div class="terms-doc-card">
					<div class="terms-doc-header">
						<svg class="terms-doc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
							<polyline points="14 2 14 8 20 8"/>
							<line x1="16" y1="13" x2="8" y2="13"/>
							<line x1="16" y1="17" x2="8" y2="17"/>
							<line x1="10" y1="9" x2="8" y2="9"/>
						</svg>
						<div>
							<div class="terms-doc-name">{f.termsDoc}</div>
							<div class="terms-doc-meta">PDF · 2 {lang === 'es' ? 'páginas' : 'pages'}</div>
						</div>
						<div class="terms-doc-actions">
							<button type="button" class="terms-toggle-btn" id="terms-toggle" aria-expanded="false" aria-controls="terms-embed">
								<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" id="terms-toggle-icon">
									<path d="M4 6l4 4 4-4"/>
								</svg>
								<span id="terms-toggle-text">
									{lang === 'es' ? 'Leer' : 'Read'}
								</span>
							</button>
							<a
								class="btn btn-outline terms-open-btn"
								href={termsDocViewUrl}
								target="_blank"
								rel="noopener noreferrer"
							>
								<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<path d="M7 3H3a1 1 0 0 0-1 1v9a1 1 0 0 0 1 1h9a1 1 0 0 0 1-1V9"/>
									<path d="M10 2h4v4M14 2l-6 6"/>
								</svg>
								{lang === 'es' ? 'Abrir' : 'Open'}
							</a>
						</div>
					</div>

					<!-- Collapsible PDF embed -->
					<div class="terms-embed-wrap" id="terms-embed" hidden>
						<iframe
							class="terms-embed"
							src={termsDocEmbedUrl}
							title={f.termsDoc}
							loading="lazy"
						></iframe>
					</div>
				</div>

				<!-- Accept checkbox -->
				<label class="accept-label">
					<input type="checkbox" name="termsAccepted" value="yes" required />
					<span class="checkbox-custom" aria-hidden="true">
						<svg viewBox="0 0 12 12" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M2 6l3 3 5-5"/>
						</svg>
					</span>
					<span class="accept-text">{f.labelTerms}</span>
				</label>
			</div>

			<!-- ── Submit ── -->
			<div class="form-submit">
				<button class="btn btn-accent submit-btn" type="submit">
					{f.submitBtn}
					<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M3 8h10M9 4l4 4-4 4"/>
					</svg>
				</button>
				<p class="submit-note muted">{f.submitNote}</p>
			</div>

		</form>

	</div>
</main>

<!-- Toggle script for PDF embed -->
<script>
	const btn = document.getElementById('terms-toggle');
	const embed = document.getElementById('terms-embed');
	const icon = document.getElementById('terms-toggle-icon');
	const label = document.getElementById('terms-toggle-text');

	if (btn && embed) {
		btn.addEventListener('click', () => {
			const isOpen = !embed.hidden;
			embed.hidden = isOpen;
			btn.setAttribute('aria-expanded', String(!isOpen));
			if (icon) icon.style.transform = isOpen ? '' : 'rotate(180deg)';
			if (label) {
				const lang = document.documentElement.lang;
				label.textContent = isOpen
					? (lang === 'es' ? 'Leer' : 'Read')
					: (lang === 'es' ? 'Cerrar' : 'Close');
			}
		});
	}
</script>

<style>
	/* ── Page shell ────────────────────────────────────────────── */
	.form-page {
		padding: 54px 0 90px;
		background: linear-gradient(180deg, rgba(0, 32, 91, 0.04) 0%, transparent 50%);
	}

	.form-container {
		max-width: 700px;
	}

	/* ── Back link ─────────────────────────────────────────────── */
	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-size: 13px;
		font-weight: 700;
		color: var(--color-primary);
		margin-bottom: 28px;
		transition: gap 0.14s ease;
	}

	.back-link:hover { gap: 10px; }
	.back-link svg { width: 16px; height: 16px; }

	/* ── Header ────────────────────────────────────────────────── */
	.form-header { margin-bottom: 32px; }

	.form-title {
		margin: 0 0 10px;
		font-size: clamp(26px, 3vw, 36px);
		letter-spacing: -0.02em;
	}

	.form-subtitle {
		margin: 0;
		color: var(--color-muted);
		line-height: 1.7;
		font-size: 15px;
	}

	/* ── Form sections ─────────────────────────────────────────── */
	form {
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.form-section {
		background: white;
		border-radius: 18px;
		border: 1px solid rgba(0, 32, 91, 0.1);
		box-shadow: 0 2px 14px rgba(0, 0, 0, 0.05);
		padding: 28px 28px 30px;
		display: flex;
		flex-direction: column;
		gap: 20px;
	}

	.section-header {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.section-num {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 26px;
		height: 26px;
		border-radius: 50%;
		background: var(--color-primary);
		color: white;
		font-size: 12px;
		font-weight: 900;
		flex-shrink: 0;
	}

	.section-num--accent { background: var(--color-accent); }

	.section-title {
		margin: 0;
		font-size: 15px;
		font-weight: 800;
		color: var(--color-text);
	}

	/* ── Fields ────────────────────────────────────────────────── */
	.contact-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 16px;
	}

	.field--full { grid-column: 1 / -1; }

	.field {
		display: flex;
		flex-direction: column;
		gap: 7px;
	}

	.field-label,
	fieldset legend.field-label {
		font-size: 12px;
		font-weight: 800;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: rgba(15, 23, 42, 0.6);
		padding: 0;
		border: none;
	}

	.req { color: var(--color-accent); margin-left: 1px; }

	.field-input {
		border: 1.5px solid rgba(0, 32, 91, 0.16);
		border-radius: 10px;
		padding: 11px 14px;
		font-size: 14px;
		font-family: var(--font-sans);
		color: var(--color-text);
		background: rgba(0, 32, 91, 0.02);
		transition: border-color 0.14s, box-shadow 0.14s;
		width: 100%;
		outline: none;
	}

	.field-input::placeholder { color: rgba(15, 23, 42, 0.3); }

	.field-input:focus {
		border-color: var(--color-primary);
		box-shadow: 0 0 0 3px rgba(42, 118, 181, 0.12);
		background: white;
	}

	.field-textarea {
		resize: vertical;
		min-height: 100px;
		line-height: 1.6;
	}

	/* ── Fieldsets ─────────────────────────────────────────────── */
	.field-group {
		border: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 10px;
	}

	/* ── Pill tabs (Donation Type) ─────────────────────────────── */
	.pill-group {
		display: flex;
		gap: 8px;
		flex-wrap: wrap;
	}

	.pill-label {
		cursor: pointer;
		flex: 1;
		min-width: 90px;
	}

	.pill-label input[type='radio'] {
		position: absolute;
		opacity: 0;
		width: 0;
		height: 0;
	}

	.pill-label span {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 10px 16px;
		border-radius: 999px;
		font-size: 14px;
		font-weight: 700;
		border: 1.5px solid rgba(0, 32, 91, 0.2);
		background: rgba(0, 32, 91, 0.03);
		color: var(--color-muted);
		transition: all 0.14s ease;
		text-align: center;
		white-space: nowrap;
	}

	.pill-label:hover span {
		border-color: var(--color-primary);
		color: var(--color-primary);
		background: rgba(42, 118, 181, 0.06);
	}

	.pill-label input:checked + span {
		background: var(--color-primary);
		border-color: var(--color-primary);
		color: white;
		box-shadow: 0 2px 10px rgba(42, 118, 181, 0.3);
	}

	.pill-label input:focus-visible + span {
		outline: 2px solid var(--color-primary);
		outline-offset: 2px;
	}

	/* ── Focus cards (Donation Focus) ─────────────────────────── */
	.focus-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 10px;
	}

	.focus-card {
		cursor: pointer;
	}

	.focus-card input[type='radio'] {
		position: absolute;
		opacity: 0;
		width: 0;
		height: 0;
	}

	.focus-card-inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 8px;
		padding: 16px 10px;
		border-radius: 14px;
		border: 1.5px solid rgba(0, 32, 91, 0.16);
		background: rgba(0, 32, 91, 0.02);
		transition: all 0.14s ease;
		text-align: center;
	}

	.focus-icon { font-size: 22px; line-height: 1; }

	.focus-name {
		font-size: 13px;
		font-weight: 700;
		color: var(--color-muted);
		transition: color 0.14s;
	}

	.focus-card:hover .focus-card-inner {
		border-color: var(--color-primary);
		background: rgba(42, 118, 181, 0.05);
	}

	.focus-card input:checked + .focus-card-inner {
		border-color: var(--color-primary);
		background: rgba(42, 118, 181, 0.08);
		box-shadow: 0 2px 10px rgba(42, 118, 181, 0.14);
	}

	.focus-card input:checked + .focus-card-inner .focus-name {
		color: var(--color-primary);
	}

	.focus-card input:focus-visible + .focus-card-inner {
		outline: 2px solid var(--color-primary);
		outline-offset: 2px;
	}

	/* ── Toggle cards (Recognition) ───────────────────────────── */
	.toggle-group {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.toggle-label { cursor: pointer; }

	.toggle-label input[type='radio'] {
		position: absolute;
		opacity: 0;
		width: 0;
		height: 0;
	}

	.toggle-box {
		display: flex;
		align-items: center;
		gap: 10px;
		padding: 12px 16px;
		border-radius: 12px;
		border: 1.5px solid rgba(0, 32, 91, 0.16);
		font-size: 14px;
		font-weight: 600;
		color: var(--color-muted);
		transition: all 0.14s ease;
	}

	.toggle-box svg {
		width: 18px;
		height: 18px;
		flex-shrink: 0;
		opacity: 0.5;
	}

	.toggle-label:hover .toggle-box {
		border-color: var(--color-primary);
		color: var(--color-primary);
		background: rgba(42, 118, 181, 0.04);
	}

	.toggle-label input:checked + .toggle-box {
		border-color: var(--color-primary);
		background: rgba(42, 118, 181, 0.08);
		color: var(--color-primary);
		font-weight: 700;
	}

	.toggle-label input:checked + .toggle-box svg { opacity: 1; }

	.toggle-label input:focus-visible + .toggle-box {
		outline: 2px solid var(--color-primary);
		outline-offset: 2px;
	}

	/* ── Checkboxes ────────────────────────────────────────────── */
	.checkbox-group {
		display: flex;
		flex-direction: column;
		gap: 10px;
	}

	.checkbox-label {
		display: flex;
		align-items: flex-start;
		gap: 10px;
		font-size: 14px;
		cursor: pointer;
		line-height: 1.5;
		color: var(--color-text);
	}

	.checkbox-label input[type='checkbox'] {
		position: absolute;
		opacity: 0;
		width: 0;
		height: 0;
	}

	.checkbox-custom {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 18px;
		height: 18px;
		border-radius: 6px;
		border: 1.5px solid rgba(0, 32, 91, 0.28);
		flex-shrink: 0;
		margin-top: 1px;
		transition: background 0.14s, border-color 0.14s;
	}

	.checkbox-custom svg {
		width: 11px;
		height: 11px;
		opacity: 0;
		transition: opacity 0.1s;
	}

	.checkbox-label input:checked + .checkbox-custom {
		background: var(--color-primary);
		border-color: var(--color-primary);
	}

