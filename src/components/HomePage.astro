		</div>
	</section>

	<style>
		/* ── Hero copy ───────────────────────────────────────── */
		.hero-copy {
			max-width: 600px;
			display: flex;
			flex-direction: column;
		}

		.hero-btn-sponsor {
			padding: 14px 30px;
			font-size: 15px;
			font-weight: 800;
			letter-spacing: 0.01em;
			box-shadow: 0 4px 24px rgba(237, 67, 76, 0.45);
		}

		.hero-btn-volunteer {
			padding: 14px 26px;
			font-size: 15px;
			font-weight: 700;
			border-color: rgba(255, 255, 255, 0.52);
		}

		.hero-btn-volunteer:hover {
			background: rgba(255, 255, 255, 0.1);
			border-color: rgba(255, 255, 255, 0.85);
		}

		/* ── Hero stats — Mobile First ───────────────────────── */
		/* Base: 3-col grid (avoids flex overflow on narrow screens) */
		.hero-stats {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 8px 0;
			margin-top: 28px;
			padding-top: 20px;
			border-top: 1px solid rgba(255, 255, 255, 0.18);
		}

		.hero-stat {
			display: flex;
			flex-direction: column;
			gap: 5px;
			padding: 0 8px;
			border-right: 1px solid rgba(255, 255, 255, 0.2);
		}

		.hero-stat:last-of-type {
			border-right: none;
		}

		/* Dividers hidden on mobile (border-right used instead) */
		.hero-stat-divider {
			display: none;
		}

		.hero-stat-num {
			font-size: clamp(22px, 6vw, 34px);
			font-weight: 900;
			color: white;
			line-height: 1;
			letter-spacing: -0.02em;
		}

		.hero-stat-label {
			font-size: 10px;
			font-weight: 600;
			color: rgba(255, 255, 255, 0.68);
			line-height: 1.35;
			word-break: break-word;
		}

		/* Tablet+: flex row with traditional dividers */
		@media (min-width: 640px) {
			.hero-stats {
				display: flex;
				align-items: center;
				gap: 0;
				margin-top: 34px;
				padding-top: 26px;
			}

			.hero-stat {
				padding: 0;
				padding-right: 28px;
				margin-right: 28px;
				border-right: none;
			}

			.hero-stat-divider {
				display: block;
				width: 1px;
				height: 38px;
				background: rgba(255, 255, 255, 0.22);
				flex-shrink: 0;
				margin-right: 28px;
			}

			.hero-stat-label {
				font-size: 12px;
				letter-spacing: 0.03em;
			}
		}

		/* ── Hero background — Ken Burns slow zoom ───────────── */
		@keyframes kenBurns {
			0%   { transform: scale(1.03); }
			50%  { transform: scale(1.10); }
			100% { transform: scale(1.03); }
		}

		.hero-bg {
			animation: kenBurns 28s ease-in-out infinite;
		}

		@media (prefers-reduced-motion: reduce) {
			.hero-bg { animation: none; }
		}

		/* ── Wave ────────────────────────────────────────────── */
		.hero-wave {
			position: absolute;
			bottom: -1px;
			left: 0;
			right: 0;
			z-index: 3;
			height: 130px;
			overflow: hidden;
			pointer-events: none;
		}

		.waves-svg {
			position: absolute;
			bottom: 0;
			left: 0;
			width: 100%;
			height: 100%;
			min-height: 60px;
		}

		/* GPU hints — cada capa en su propio compositor layer */
		.waves-parallax use {
			transform: translateZ(0);
			will-change: transform;
			backface-visibility: hidden;
			animation: gentleWave 25s cubic-bezier(0.5, 0.5, 0.45, 0.5) infinite;
		}

		/* Velocidades distintas por capa → efecto paralaje natural */
		.waves-parallax use:nth-child(1) { animation-duration:  7s; animation-delay: -2s; }
		.waves-parallax use:nth-child(2) { animation-duration: 10s; animation-delay: -3s; }
		.waves-parallax use:nth-child(3) { animation-duration: 13s; animation-delay: -4s; }
		.waves-parallax use:nth-child(4) { animation-duration: 20s; animation-delay: -5s; }

		@keyframes gentleWave {
			0%   { transform: translate3d(-90px, 0, 0); }
			100% { transform: translate3d( 85px, 0, 0); }
		}

		/* Respect prefers-reduced-motion */
		@media (prefers-reduced-motion: reduce) {
			.waves-parallax use { animation: none; }
		}

		@media (max-width: 640px) {
			.hero-stats {
				gap: 0;
			}

			.hero-stat {
				padding-right: 18px;
				margin-right: 18px;
			}

			.hero-stat-divider {
				margin-right: 18px;
			}

			.hero-stat-num {
				font-size: 24px;
			}

			.hero-wave {
				height: 70px;
			}
		}

		/* ── Programs ─────────────────────────────────────────── */
		.programs-list {
			display: flex;
			flex-direction: column;
			gap: 14px;
		}

		.program-card {
			display: flex;
			align-items: flex-start;
			gap: 14px;
			padding: 18px 20px;
			transition: transform 0.22s ease, box-shadow 0.22s ease;
		}

		.program-card:hover {
			transform: translateY(-4px);
			box-shadow: 0 20px 48px rgba(0, 0, 0, 0.18);
		}

		.program-card:hover .program-icon {
			color: #5ca8e0;
		}

		.program-icon {
			width: 40px;
			height: 40px;
			flex-shrink: 0;
			color: var(--color-primary);
			display: flex;
			align-items: center;
			justify-content: center;
		}

		.program-icon svg {
			width: 26px;
			height: 26px;
		}

		.program-name {
			font-weight: 900;
			font-size: 15px;
			color: var(--color-text);
		}

		/* ── Impact stats — Mobile First ─────────────────────── */
		.impact-grid {
			display: grid;
			grid-template-columns: repeat(2, 1fr); /* mobile: 2 cols */
			gap: 12px;
		}

		.impact-stat {
			background: var(--panel-bg, white);
			border: 1px solid var(--color-border, rgba(0,32,91,0.1));
			border-radius: 16px;
			padding: 22px 18px;
			display: flex;
			flex-direction: column;
			gap: 6px;
			transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
		}

		.impact-stat:hover {
			transform: translateY(-4px);
			box-shadow: 0 16px 36px rgba(0, 32, 91, 0.12);
			border-color: rgba(42, 118, 181, 0.3);
		}

		.impact-number {
			font-size: clamp(30px, 4vw, 42px);
			font-weight: 900;
			color: var(--color-primary);
			line-height: 1;
		}

		.impact-label {
			font-size: 13px;
			font-weight: 700;
			color: var(--color-muted);
			line-height: 1.3;
		}

		/* Desktop: 4 cols for impact stats */
		@media (min-width: 860px) {
			.impact-grid {
				grid-template-columns: repeat(4, minmax(0, 1fr));
				gap: 16px;
				margin-top: 32px;
			}
		}

		/* ── Reopen Hermosa campaign ─────────────────────────────── */
		.reopen {
			position: relative;
			padding: 72px 0 80px;
			overflow: hidden;
		}

		.reopen-bg {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			object-fit: cover;
			filter: saturate(0.9) contrast(1.06) brightness(0.65);
		}

		.reopen-overlay {
			position: absolute;
			inset: 0;
			background: linear-gradient(135deg, rgba(0,32,91,0.88) 0%, rgba(0,10,40,0.75) 100%);
		}

		.reopen-inner {
			position: relative;
			z-index: 2;
			display: grid;
			grid-template-columns: 1fr;
			gap: 44px;
			align-items: center;
		}

		@media (min-width: 860px) {
			.reopen-inner {
				grid-template-columns: 1fr 1fr;
				gap: 60px;
			}
		}

		/* Left copy */
		.reopen-copy {
			color: white;
		}

		.reopen-kicker {
			color: rgba(255,255,255,0.62) !important;
			border-color: rgba(255,255,255,0.22) !important;
		}

		.reopen-title {
			color: white;
			margin: 12px 0 18px;
			font-size: clamp(26px, 3.5vw, 40px);
		}

		.reopen-body {
