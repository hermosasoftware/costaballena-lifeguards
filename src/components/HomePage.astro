			font-size: 15px;
			line-height: 1.75;
			margin: 0 0 24px;
			max-width: 46ch;
		}

		/* Dominical success badge */
		.reopen-dominical {
			display: flex;
			align-items: center;
			gap: 12px;
			background: rgba(34,197,94,0.12);
			border: 1px solid rgba(34,197,94,0.28);
			border-radius: 12px;
			padding: 12px 16px;
			margin-bottom: 28px;
			font-size: 13.5px;
		}

		.reopen-dominical strong {
			color: #4ade80;
		}

		.reopen-dominical span {
			color: rgba(255,255,255,0.6);
		}

		.reopen-dominical-dot {
			width: 10px;
			height: 10px;
			border-radius: 50%;
