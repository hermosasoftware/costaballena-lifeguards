			align-items: center;
			gap: 7px;
			font-size: 11.5px;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.08em;
			color: #fbbf24;
		}

		.reopen-card-status-dot {
			width: 7px;
			height: 7px;
			border-radius: 50%;
			background: #fbbf24;
			animation: pulse-dot 1.8s ease-in-out infinite;
			box-shadow: 0 0 0 3px rgba(251,191,36,0.25);
		}

		/* Amount */
		.reopen-amount-row {
			display: flex;
			align-items: flex-end;
			justify-content: space-between;
			gap: 16px;
			margin-bottom: 20px;
		}

		.reopen-amount {
			font-size: clamp(44px, 6vw, 64px);
			font-weight: 900;
			color: white;
			line-height: 1;
			letter-spacing: -0.04em;
		}

		.reopen-amount-label {
			font-size: 12.5px;
			color: rgba(255,255,255,0.48);
			margin-top: 6px;
		}

		.reopen-pct {
			font-size: clamp(28px, 4vw, 40px);
			font-weight: 900;
			color: var(--color-primary-400);
			letter-spacing: -0.02em;
			line-height: 1;
			padding-bottom: 4px;
		}

		/* Progress bar */
		.reopen-bar-track {
			position: relative;
			height: 14px;
			background: rgba(255,255,255,0.1);
			border-radius: 999px;
			overflow: visible;
			margin-bottom: 8px;
		}

		.reopen-bar-fill {
			height: 100%;
			width: 0;
			background: linear-gradient(90deg, var(--color-primary-600), var(--color-primary-400), #60a5fa);
			border-radius: 999px;
			transition: width 1.6s cubic-bezier(0.22, 1, 0.36, 1);
			position: relative;
		}

		.reopen-bar-fill.bar-animated {
			width: var(--reopen-fill-pct, 60%);
		}

		.reopen-bar-fill::after {
			content: '';
			position: absolute;
			right: -1px;
			top: 50%;
			transform: translateY(-50%);
			width: 18px;
			height: 18px;
			border-radius: 50%;
			background: white;
			border: 3px solid var(--color-primary-400);
			box-shadow: 0 0 0 4px rgba(77,146,200,0.3);
			opacity: 0;
			transition: opacity 0.3s ease 1.2s;
		}

		.reopen-bar-fill.bar-animated::after {
			opacity: 1;
		}

		.reopen-bar-marker {
			position: absolute;
			top: -6px;
			transform: translateX(-50%);
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 4px;
			pointer-events: none;
		}

		.reopen-bar-marker::before {
			content: '';
			width: 1px;
			height: 26px;
			background: rgba(255,255,255,0.2);
		}

		.reopen-bar-marker-label {
			font-size: 10px;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.06em;
			color: rgba(255,255,255,0.3);
			white-space: nowrap;
		}

		/* Bar scale */
		.reopen-bar-scale {
			display: flex;
			justify-content: space-between;
			font-size: 11px;
			font-weight: 600;
			color: rgba(255,255,255,0.28);
			margin-bottom: 20px;
			letter-spacing: 0.02em;
			margin-top: 28px;
		}

		.reopen-card-note {
			font-size: 12.5px;
			color: rgba(255,255,255,0.38);
			line-height: 1.6;
			padding-top: 16px;
			border-top: 1px solid rgba(255,255,255,0.08);
			font-style: italic;
		}
		/* ── Combined section (bg-base, flows from wave) ─────────── */
		.combined-section {
			padding: 72px 0 80px;
		}

		.combined-sep {
			height: 1px;
			background: rgba(255, 255, 255, 0.1);
			margin: 60px 0;
		}

		/* ── Reality part ────────────────────────────────────────── */
		.cs-reality {
			text-align: center;
		}

		/* Kicker con estilo pill/badge — borde sutil sobre dark bg */
		.cs-reality-kicker {
			display: inline-block;
			padding: 5px 16px;
			border: 1px solid rgba(255, 255, 255, 0.22);
			border-radius: 999px;
			background: rgba(255, 255, 255, 0.06);
			font-size: 11px;
			font-weight: 700;
			letter-spacing: 0.13em;
			text-transform: uppercase;
			color: rgba(255, 255, 255, 0.55);
			margin-bottom: 28px;
		}

		/* Primera frase — titular prominente */
		.reality-heading {
			margin: 0 auto 18px;
			max-width: 30ch;
			font-size: clamp(28px, 4vw, 48px);
			font-weight: 700;
			line-height: 1.2;
			letter-spacing: -0.02em;
			color: white;
		}

		/* Segunda frase — subtítulo */
		.reality-sub {
			margin: 0 auto;
			max-width: 52ch;
			font-size: clamp(15px, 1.6vw, 18px);
			font-weight: 400;
			line-height: 1.7;
			color: rgba(255, 255, 255, 0.62);
		}

		.reality-accent {
			color: #e07a80;
			font-style: italic;
			font-weight: 600;
		}

		/* ── Support cards — glass + per-card color accent ──────── */

		/*
		 * Icon circle color per card — all from the blue/navy family.
		 * White SVG on colored circle = always visible, modern, friendly.
		 * The accent red stays reserved for CTA buttons only.
		 */
		.cs-support .support-card:nth-child(1) { --card-color: #2a76b5; --card-icon-bg: rgba(42, 118, 181, 0.35); }
		.cs-support .support-card:nth-child(2) { --card-color: #4d92c8; --card-icon-bg: rgba(77, 146, 200, 0.35); }
		.cs-support .support-card:nth-child(3) { --card-color: #1d5485; --card-icon-bg: rgba(29,  84, 133, 0.45); }
		.cs-support .support-card:nth-child(4) { --card-color: #3a6090; --card-icon-bg: rgba(58, 96, 144, 0.38); }

		.cs-support .support-card {
			position: relative;
			overflow: hidden;
			background: rgba(255, 255, 255, 0.05);
			border: 1px solid rgba(255, 255, 255, 0.09);
			border-radius: 24px;
			padding: 28px 22px 28px;
			box-shadow: none;
			transition: transform 0.26s cubic-bezier(0.22,1,0.36,1),
			            background 0.26s ease, border-color 0.26s ease,
			            box-shadow 0.26s ease;
		}

		/* Gradient border top — slides in from left on hover */
		.cs-support .support-card::after {
			content: '';
			position: absolute;
			top: 0;
			left: 0;
			right: 0;
			height: 3px;
			background: linear-gradient(
				90deg,
				var(--color-base)    0%,
				var(--color-primary) 50%,
				var(--color-accent)  100%
			);
			border-radius: 24px 24px 0 0;
			transform: scaleX(0);
			transform-origin: left center;
			transition: transform 0.35s cubic-bezier(0.22,1,0.36,1);
		}

		.cs-support .support-card:hover::after {
			transform: scaleX(1);
		}

		.cs-support .support-card:hover {
			background: rgba(255, 255, 255, 0.10);
			border-color: rgba(255, 255, 255, 0.20);
			box-shadow: 0 22px 52px rgba(0, 0, 0, 0.35);
			transform: translateY(-8px);
		}

		/* Icon: circular, always white SVG, colored circle background */
		.cs-support .support-card-icon {
			width: 52px;
			height: 52px;
			border-radius: 50%;
			background: var(--card-icon-bg);
			color: white;
			margin-bottom: 20px;
			transition: background 0.26s ease, transform 0.26s ease;
		}

		.cs-support .support-card-icon svg {
			width: 22px;
			height: 22px;
		}

		.cs-support .support-card:hover .support-card-icon {
			background: var(--card-color);
			transform: scale(1.1) rotate(-4deg);
		}

		.cs-support .support-card-title {
			color: white;
			font-size: 15px;
			font-weight: 700;
			margin: 0 0 8px;
		}

		.cs-support .support-card-desc {
			color: rgba(255, 255, 255, 0.58);
			font-size: 13.5px;
			line-height: 1.65;
			margin: 0;
		}

		/* ── Where section — fondo claro ────────────────────────── */
		.where-section {
			background: #f5f7fc;
			padding: 80px 0;
		}

		.cs-where-grid {
			align-items: center;
			gap: 56px;
		}

		/* Heading: primera línea normal, segunda bold + color */
		.where-heading {
			font-size: clamp(26px, 3.2vw, 40px);
			font-weight: 400;
			line-height: 1.2;
			letter-spacing: -0.02em;
			color: var(--color-text);
			margin: 10px 0 18px;
		}

		.where-heading span {
			display: block;
			font-weight: 800;
			color: var(--color-base);
		}

		.where-intro {
			font-size: 14px;
			font-weight: 600;
			text-transform: uppercase;
			letter-spacing: 0.07em;
			color: var(--color-primary);
			margin: 0 0 12px;
		}

		/* Numbered list */
		.where-num-list {
			list-style: none;
			padding: 0;
			margin: 0;
			display: flex;
			flex-direction: column;
			gap: 12px;
		}

		.where-num-list li {
			display: flex;
			align-items: center;
			gap: 14px;
		}

		.where-num {
			flex-shrink: 0;
			width: 30px;
			height: 30px;
			border-radius: 50%;
			background: var(--color-base);
			color: white;
			font-size: 13px;
			font-weight: 700;
			display: flex;
			align-items: center;
			justify-content: center;
			line-height: 1;
		}

		.where-item-text {
			font-size: 15px;
			font-weight: 500;
			color: var(--color-text);
			line-height: 1.4;
		}

		/* Trust note row */
		.where-trust {
			display: flex;
			align-items: flex-start;
			gap: 10px;
			margin-top: 22px;
			padding: 14px 16px;
			background: white;
			border-left: 3px solid var(--color-primary);
			border-radius: 0 8px 8px 0;
		}

		.where-trust-icon {
			width: 18px;
			height: 18px;
			color: var(--color-primary);
			flex-shrink: 0;
			margin-top: 1px;
		}

		.where-trust-text {
			font-size: 13.5px;
			font-style: italic;
			color: var(--color-muted);
			line-height: 1.55;
			margin: 0;
		}

		/* Image column with floating badge */
		.where-img-wrap {
			position: relative;
			border-radius: 20px;
			overflow: hidden;
			box-shadow: 0 24px 56px rgba(0, 32, 91, 0.14);
		}

		.where-img {
			width: 100%;
			aspect-ratio: 4/3;
			object-fit: cover;
			display: block;
		}

		/* Floating badge — overlaps bottom-left of image */
		.where-badge {
			position: absolute;
			bottom: 16px;
			left: 16px;
			display: flex;
			align-items: center;
			gap: 10px;
			background: white;
			border-radius: 12px;
			padding: 10px 14px;
			box-shadow: 0 8px 24px rgba(0, 32, 91, 0.18);
		}

		.where-badge svg {
			width: 18px;
			height: 18px;
			color: var(--color-accent);
			flex-shrink: 0;
			stroke-width: 2.5;
		}

		.where-badge div {
			display: flex;
			flex-direction: column;
			gap: 1px;
		}

		.where-badge strong {
			font-size: 13px;
			font-weight: 700;
			color: var(--color-text);
			line-height: 1.2;
		}

		.where-badge span {
			font-size: 11px;
			color: var(--color-muted);
			line-height: 1.2;
		}

		/* ── Programs accordion ──────────────────────────────────── */
		.prog-section {
			background: #f5f7fc;
			padding: 80px 0 72px;
		}

		.prog-header {
			display: flex;
			flex-direction: column;
			gap: 12px;
			margin-bottom: 48px;
		}

		@media (min-width: 720px) {
			.prog-header {
				flex-direction: row;
				align-items: flex-end;
				justify-content: space-between;
				gap: 40px;
			}
		}

		.prog-header-text {
			flex-shrink: 0;
		}

		.prog-header .kicker {
			color: var(--color-primary) !important;
			border-color: rgba(42, 118, 181, 0.28) !important;
		}

		.prog-title {
			font-size: clamp(32px, 4vw, 52px);
			font-weight: 800;
			color: var(--color-base);
			letter-spacing: -0.025em;
			margin: 8px 0 0;
		}

		.prog-header-sub {
			font-size: 15px;
			line-height: 1.65;
			color: rgba(0, 32, 91, 0.52);
			max-width: 38ch;
			margin: 0;
			padding-bottom: 4px;
		}

		/* Two-column layout */
		.prog-layout {
			display: grid;
			grid-template-columns: 1fr;
			gap: 40px;
		}

		@media (min-width: 860px) {
			.prog-layout {
				grid-template-columns: 55% 1fr;
				gap: 56px;
				align-items: start;
			}
		}

		/* ── Accordion list ─────────── */
		.prog-list {
			display: flex;
			flex-direction: column;
		}

		.prog-divider {
			height: 1px;
			background: rgba(0, 32, 91, 0.13);
		}

		.prog-item {
			cursor: pointer;
			outline: none;
		}

		.prog-item-body {
			display: flex;
			gap: 20px;
			padding: 20px 16px 20px 20px;
			border-left: 3px solid transparent;
			border-radius: 0 12px 12px 0;
			margin-left: -3px;
			transition:
				padding 0.35s cubic-bezier(0.22, 1, 0.36, 1),
				border-color 0.3s ease,
				background 0.3s ease;
		}

		.prog-item.is-active .prog-item-body {
			padding: 26px 16px 26px 20px;
			border-left-color: var(--color-primary);
			background: rgba(42, 118, 181, 0.06);
		}

		.prog-meta {
			padding-top: 6px;
			flex-shrink: 0;
		}

		.prog-num {
			width: 30px;
			height: 30px;
			border-radius: 50%;
			border: 1.5px solid rgba(0, 32, 91, 0.2);
			background: transparent;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 10.5px;
			font-weight: 800;
			letter-spacing: 0.04em;
			color: rgba(0, 32, 91, 0.4);
			font-variant-numeric: tabular-nums;
			flex-shrink: 0;
			transition:
				background 0.3s ease,
				border-color 0.3s ease,
				color 0.3s ease;
		}

		.prog-item.is-active .prog-num {
			background: var(--color-primary);
			border-color: var(--color-primary);
			color: white;
		}

		.prog-item:hover:not(.is-active) .prog-num {
			border-color: rgba(0, 32, 91, 0.45);
			color: rgba(0, 32, 91, 0.65);
		}

		.prog-content {
			flex: 1;
		}

		.prog-name {
			font-size: clamp(22px, 2.8vw, 36px);
			font-weight: 700;
			letter-spacing: -0.02em;
			line-height: 1.15;
			color: rgba(0, 32, 91, 0.42);
			margin: 0;
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 12px;
			transition: color 0.3s ease;
		}

		.prog-item:hover .prog-name {
			color: rgba(0, 32, 91, 0.72);
		}

		.prog-item.is-active .prog-name {
			color: var(--color-base);
		}

		.prog-arrow {
			font-size: 0.65em;
			opacity: 0;
			transform: translateX(-10px);
			transition: opacity 0.3s ease, transform 0.3s ease;
			flex-shrink: 0;
			color: var(--color-primary);
		}

		.prog-item.is-active .prog-arrow {
			opacity: 1;
			transform: translateX(0);
		}

		/* Expandable description */
		.prog-desc {
			max-height: 0;
			overflow: hidden;
			transition: max-height 0.45s cubic-bezier(0.22, 1, 0.36, 1);
		}

		.prog-item.is-active .prog-desc {
			max-height: 160px;
		}

		.prog-desc p {
			margin: 12px 0 0;
			font-size: 15px;
			line-height: 1.7;
			color: rgba(0, 32, 91, 0.6);
		}

		/* CTA below list */
		.prog-cta {
			display: flex;
			align-items: center;
			gap: 20px;
			margin-top: 36px;
			flex-wrap: wrap;
		}

		.prog-cta-note {
			font-size: 13px;
			color: rgba(0, 32, 91, 0.45);
			margin: 0;
		}

		/* CTA button on light bg: outline dark */
		.prog-cta .btn-outline {
			border-color: rgba(0, 32, 91, 0.35);
			color: var(--color-base);
		}

		.prog-cta .btn-outline:hover {
			background: var(--color-base);
			border-color: var(--color-base);
			color: white;
		}

		/* ── Image preview ──────────── */
		.prog-preview {
			display: none;
		}

		@media (min-width: 860px) {
			.prog-preview {
				display: block;
				position: sticky;
				top: 90px;
			}
		}

		.prog-img-stack {
			position: relative;
			border-radius: 20px;
			overflow: hidden;
			aspect-ratio: 3/4;
			background: rgba(0, 32, 91, 0.06);
			box-shadow: 0 16px 48px rgba(0, 32, 91, 0.14);
		}

		.prog-img {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			object-fit: cover;
			opacity: 0;
			transition: opacity 0.55s cubic-bezier(0.22, 1, 0.36, 1),
			            transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
			transform: scale(1.04);
		}

		.prog-img.is-active {
			opacity: 1;
			transform: scale(1);
		}

		/* ── Impact section — dark (bg-base) ────────────────────── */
		.impact-section {
			padding: 80px 0 72px;
		}

		.impact-header {
			text-align: center;
			margin-bottom: 56px;
		}

		.impact-title {
			color: white;
			margin: 8px 0 10px;
		}

		.impact-subtitle {
			color: rgba(255, 255, 255, 0.62);
			font-size: 16px;
			margin: 0 0 8px;
		}

		.impact-period {
			display: inline-block;
			font-size: 11.5px;
			font-weight: 600;
			letter-spacing: 0.08em;
			text-transform: uppercase;
			color: rgba(255, 255, 255, 0.3);
			border: 1px solid rgba(255, 255, 255, 0.14);
			border-radius: 999px;
			padding: 4px 14px;
		}

		/* Prevention hero block */
		.impact-prevention {
			display: grid;
			grid-template-columns: 1fr;
			gap: 36px;
			background: rgba(255, 255, 255, 0.04);
			border: 1px solid rgba(255, 255, 255, 0.09);
			border-radius: 20px;
			padding: 36px 32px;
			margin-bottom: 24px;
		}

		@media (min-width: 720px) {
			.impact-prevention {
				grid-template-columns: auto 1fr;
				gap: 52px;
				align-items: center;
			}
		}

		.impact-big-num {
			font-size: clamp(52px, 8vw, 88px);
			font-weight: 900;
			color: white;
			line-height: 1;
			letter-spacing: -0.04em;
		}

		.impact-big-label {
			font-size: 13px;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.1em;
			color: var(--color-primary-400);
			margin-top: 6px;
		}

		.impact-prev-note {
			color: rgba(255, 255, 255, 0.5);
			font-size: 13.5px;
			line-height: 1.65;
			margin: 14px 0 0;
			max-width: 32ch;
			font-style: italic;
		}

		/* Bars */
		.impact-prev-bars {
			display: flex;
			flex-direction: column;
			gap: 20px;
		}

		.impact-bar-group {}

		.impact-bar-header {
			display: flex;
			justify-content: space-between;
			align-items: baseline;
			margin-bottom: 8px;
			font-size: 13.5px;
		}

		.impact-bar-header span {
			color: rgba(255, 255, 255, 0.58);
		}

		.impact-bar-header strong {
			color: white;
			font-size: 15px;
			font-weight: 700;
		}

		.impact-bar-track {
			height: 8px;
			background: rgba(255, 255, 255, 0.1);
			border-radius: 999px;
			overflow: hidden;
		}

		.impact-bar-fill {
			height: 100%;
			width: 0;
			background: linear-gradient(90deg, var(--color-primary-600), var(--color-primary-400));
			border-radius: 999px;
			transition: width 1.4s cubic-bezier(0.22, 1, 0.36, 1);
		}

		.impact-bar-fill.bars-animated {
			width: var(--bar-w);
		}

		/* 3-column metrics */
		.impact-metrics {
			display: grid;
			grid-template-columns: 1fr;
			gap: 16px;
			margin-bottom: 24px;
		}

		@media (min-width: 600px) {
			.impact-metrics {
				grid-template-columns: repeat(3, 1fr);
			}
		}

		.impact-metric {
			background: rgba(255, 255, 255, 0.05);
			border: 1px solid rgba(255, 255, 255, 0.09);
			border-radius: 16px;
			padding: 28px 24px;
			display: flex;
			flex-direction: column;
			gap: 4px;
		}

		.impact-metric-icon {
			width: 36px;
			height: 36px;
			border-radius: 50%;
			background: rgba(255, 255, 255, 0.1);
			color: rgba(255, 255, 255, 0.7);
			display: flex;
			align-items: center;
			justify-content: center;
			margin-bottom: 12px;
		}

		.impact-metric-icon svg {
			width: 18px;
			height: 18px;
		}

		.impact-metric-icon--success {
			background: rgba(34, 197, 94, 0.18);
			color: #4ade80;
		}

		.impact-metric-num {
			font-size: clamp(36px, 5vw, 52px);
			font-weight: 900;
			color: white;
			line-height: 1;
			letter-spacing: -0.03em;
		}

		.impact-metric-label {
			font-size: 12px;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.09em;
			color: rgba(255, 255, 255, 0.45);
			margin-top: 4px;
		}

		.impact-metric-breakdown {
			display: flex;
			gap: 12px;
			margin-top: 10px;
			flex-wrap: wrap;
		}

		.impact-metric-breakdown span {
			font-size: 12.5px;
			color: rgba(255, 255, 255, 0.42);
		}

		.impact-metric-breakdown strong {
			color: rgba(255, 255, 255, 0.72);
		}

		/* Zero card */
		.impact-metric--zero {
			border-color: rgba(34, 197, 94, 0.22);
			background: rgba(34, 197, 94, 0.06);
		}

		.impact-metric-zero {
			font-size: clamp(52px, 7vw, 72px);
			font-weight: 900;
			color: #4ade80;
			line-height: 1;
			letter-spacing: -0.04em;
		}

		.impact-metric-zero-note {
			font-size: 13px;
			color: rgba(34, 197, 94, 0.7);
			font-style: italic;
			line-height: 1.5;
			margin: 8px 0 0;
		}

		/* Off-duty contrast block */
		.impact-contrast {
			background: rgba(237, 67, 76, 0.07);
			border: 1px solid rgba(237, 67, 76, 0.22);
			border-radius: 16px;
			padding: 32px;
		}

		.impact-contrast-badge {
			display: inline-block;
			font-size: 10.5px;
			font-weight: 800;
			text-transform: uppercase;
			letter-spacing: 0.12em;
			color: var(--color-accent-400);
			border: 1px solid rgba(237, 67, 76, 0.3);
			border-radius: 999px;
			padding: 4px 12px;
			margin-bottom: 20px;
		}

		.impact-contrast-body {
			display: grid;
			grid-template-columns: 1fr;
			gap: 24px;
		}

		@media (min-width: 640px) {
			.impact-contrast-body {
				grid-template-columns: 1fr 1fr;
				align-items: center;
			}
		}

		.impact-contrast-num {
			font-size: clamp(56px, 8vw, 80px);
			font-weight: 900;
			color: var(--color-accent-400);
			line-height: 1;
			letter-spacing: -0.04em;
		}

		.impact-contrast-label {
			font-size: 13px;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.08em;
			color: rgba(255, 255, 255, 0.5);
			margin-top: 4px;
		}

		.impact-contrast-note {
			font-size: 14px;
			line-height: 1.65;
			color: rgba(255, 255, 255, 0.55);
			margin: 12px 0 0;
			max-width: 42ch;
		}

		.impact-contrast-breakdown {
			display: flex;
			flex-direction: column;
			gap: 10px;
		}

		.impact-contrast-row {
			display: flex;
			justify-content: space-between;
			align-items: center;
			padding: 10px 16px;
			background: rgba(255, 255, 255, 0.04);
			border-radius: 8px;
			font-size: 14px;
		}

		.impact-contrast-row span {
			color: rgba(255, 255, 255, 0.6);
		}

		.impact-contrast-row strong {
			color: var(--color-accent-400);
			font-size: 18px;
			font-weight: 800;
		}

		/* ── Support feature cards ───────────────────────────────── */
		.support-cards-grid {
			display: grid;
			grid-template-columns: 1fr;
			gap: 16px;
		}

		@media (min-width: 540px) {
			.support-cards-grid {
				grid-template-columns: repeat(2, 1fr);
			}
		}

		@media (min-width: 900px) {
			.support-cards-grid {
				grid-template-columns: repeat(4, 1fr);
			}
		}

		.support-card {
			padding: 24px 20px 28px;
			display: flex;
			flex-direction: column;
			gap: 12px;
			transition: transform 0.22s ease, box-shadow 0.22s ease;
		}

		.support-card:hover {
			transform: translateY(-5px);
			box-shadow: 0 20px 44px rgba(0, 0, 0, 0.12);
		}

		.support-card:hover .support-card-icon {
			background: rgba(42, 118, 181, 0.22);
			transform: scale(1.08);
		}

		.support-card-icon {
			width: 46px;
			height: 46px;
			border-radius: var(--radius-md);
			background: rgba(42, 118, 181, 0.12);
			border-radius: 12px;
			display: flex;
			align-items: center;
			justify-content: center;
			color: var(--color-primary);
			flex-shrink: 0;
			transition: background 0.22s ease, transform 0.22s ease;
		}

		.support-card-icon svg {
			width: 22px;
			height: 22px;
		}

		.support-card-title {
			font-weight: 800;
			font-size: 15px;
			color: white;
			margin: 0;
		}

		.support-card-desc {
			font-size: 13.5px;
			line-height: 1.6;
			margin: 0;
		}


		/* ── Bottom CTA — dark navy section ─────────────────────── */
		/* ── Bottom CTA ─────────────────────────────────────────── */
		.bottom-cta-section {
			position: relative;
			padding: 96px 0 100px;
			overflow: hidden;
		}

		/* Background image with Ken Burns zoom */
		.bottom-cta-bg {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			object-fit: cover;
			object-position: center 40%;
			filter: saturate(0.85) brightness(0.7);
			animation: heroBgZoom 18s ease-in-out infinite alternate;
		}

		/* Overlay: deep radial gradient — darker center for text, fades at edges */
		.bottom-cta-overlay {
			position: absolute;
			inset: 0;
			background:
				radial-gradient(ellipse 80% 100% at 50% 50%, rgba(0, 12, 40, 0.78) 0%, rgba(0, 8, 28, 0.62) 100%),
				linear-gradient(180deg, rgba(0, 32, 91, 0.55) 0%, rgba(0, 8, 28, 0.82) 100%);
		}

		.bottom-cta-inner {
			position: relative;
			z-index: 2;
			text-align: center;
		}

		/* Mini stats row */
		.cta-stats {
			display: flex;
			align-items: center;
			justify-content: center;
			gap: 20px;
			margin-bottom: 40px;
			flex-wrap: wrap;
		}

		.cta-stat {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 3px;
		}

		.cta-stat-num {
			font-size: clamp(22px, 3vw, 32px);
			font-weight: 900;
			color: white;
			letter-spacing: -0.03em;
			line-height: 1;
		}

		.cta-stat-label {
			font-size: 10.5px;
			font-weight: 600;
			text-transform: uppercase;
			letter-spacing: 0.1em;
			color: rgba(255, 255, 255, 0.5);
		}

		.cta-stat-sep {
			width: 1px;
			height: 36px;
			background: rgba(255, 255, 255, 0.2);
			flex-shrink: 0;
		}

		/* Headline */
		.bottom-cta-title {
			font-size: clamp(32px, 5vw, 56px);
			font-weight: 900;
			color: white;
			letter-spacing: -0.03em;
			line-height: 1.1;
			margin: 0 0 16px;
		}

		/* Subtitle */
		.bottom-cta-sub {
			color: rgba(255, 255, 255, 0.68);
			font-size: 16px;
			line-height: 1.75;
			max-width: 56ch;
			margin: 0 auto 36px;
		}

		/* Actions */
		.bottom-cta-actions {
			display: flex;
			flex-wrap: wrap;
			gap: 12px;
			justify-content: center;
			align-items: center;
		}

		.bottom-cta-primary {
			padding: 14px 32px;
			font-size: 15px;
		}

		.bottom-cta-volunteer {
			border-color: rgba(255, 255, 255, 0.35);
			color: white;
			padding: 14px 28px;
			font-size: 15px;
		}

		.bottom-cta-volunteer:hover {
			background: rgba(255, 255, 255, 0.1);
			border-color: rgba(255, 255, 255, 0.7);
		}
	</style>
</main>

<script>
	// ── Reopen: animated amount counter + progress bar ────────
	(function () {
		const section = document.getElementById('reopen-section');
		if (!section) return;
		let done = false;

		function parseCampaignNum(value: string | undefined, fallback: number) {
			const n = Number(value);
			return Number.isFinite(n) ? n : fallback;
		}

		const targetRaised = parseCampaignNum(section.dataset.reopenRaised, 60000);
		const targetPct = parseCampaignNum(section.dataset.reopenPct, 60);

		function easeOut(t: number) { return 1 - Math.pow(1 - t, 3); }

		function animateAmount(target: number, pctGoal: number, duration: number) {
			const amountEl = document.getElementById('reopen-amount');
			const pctEl    = document.getElementById('reopen-pct');
			const barEl    = document.getElementById('reopen-bar');
			if (!amountEl || !pctEl || !barEl) return;

			const start = performance.now();
			const finalAmount = '$' + target.toLocaleString('en-US');
			const finalPct = pctGoal + '%';

			const tick = (now: number) => {
				const p = Math.min((now - start) / duration, 1);
				const e = easeOut(p);
				amountEl.textContent = '$' + Math.floor(e * target).toLocaleString('en-US');
				pctEl.textContent = Math.floor(e * pctGoal) + '%';
				if (p < 1) requestAnimationFrame(tick);
				else {
					amountEl.textContent = finalAmount;
					pctEl.textContent = finalPct;
				}
			};
			requestAnimationFrame(tick);

			// Bar fill (CSS transition — add class after small delay)
			setTimeout(() => barEl.classList.add('bar-animated'), 150);
		}

		const obs = new IntersectionObserver(
			(entries) => {
				if (entries[0].isIntersecting && !done) {
					done = true;
					animateAmount(targetRaised, targetPct, 1800);
					obs.disconnect();
				}
			},
			{ threshold: 0.3 }
		);
		obs.observe(section);
	})();

	// ── Impact: animated counters + bars on scroll ────────────
	(function () {
		const section = document.getElementById('impact-section');
		if (!section) return;

		let animated = false;

		function easeOut(t: number) { return 1 - Math.pow(1 - t, 3); }

		function animateCounter(el: HTMLElement, target: number, duration: number, suffix = '') {
			const start = performance.now();
			const update = (now: number) => {
				const progress = Math.min((now - start) / duration, 1);
				el.textContent = Math.floor(easeOut(progress) * target).toLocaleString() + (progress === 1 ? suffix : '');
				if (progress < 1) requestAnimationFrame(update);
			};
			requestAnimationFrame(update);
		}

		function runAnimations() {
			if (animated) return;
			animated = true;

			// Counters
			document.querySelectorAll<HTMLElement>('[data-count]').forEach(el => {
				const target = parseInt(el.dataset.count || '0');
				const suffix = el.dataset.suffix || '';
				animateCounter(el, target, 1600, suffix);
			});

			// Bars — staggered
			document.querySelectorAll<HTMLElement>('.impact-bar-fill').forEach((bar, i) => {
				setTimeout(() => bar.classList.add('bars-animated'), 300 + i * 200);
			});
		}

		const obs = new IntersectionObserver(
			(entries) => { if (entries[0].isIntersecting) { runAnimations(); obs.disconnect(); } },
			{ threshold: 0.2 }
		);
		obs.observe(section);
	})();

	// ── Programs accordion: hover on desktop, click on mobile ──
	(function () {
		const items = document.querySelectorAll<HTMLElement>('.prog-item');
		const imgs  = document.querySelectorAll<HTMLElement>('.prog-img');

		if (!items.length) return;

		function activate(index: number) {
			items.forEach((el, i) => el.classList.toggle('is-active', i === index));
			imgs.forEach((el, i)  => el.classList.toggle('is-active', i === index));
		}

		const isMobile = () => window.matchMedia('(max-width: 859px)').matches;

		items.forEach((item, i) => {
			// Desktop: mouseenter
			item.addEventListener('mouseenter', () => {
				if (!isMobile()) activate(i);
			});
			// Mobile / keyboard: click / Enter
			item.addEventListener('click', () => activate(i));
			item.addEventListener('keydown', (e: KeyboardEvent) => {
				if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activate(i); }
			});
		});
	})();
</script>

