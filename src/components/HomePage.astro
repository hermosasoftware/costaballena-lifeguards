---
import { copy, type Lang, formatPlayaHermosaRaisedOf } from '../i18n/copy';
import { getRoutes } from '../i18n/routes';
import TiersSection from './TiersSection.astro';

import heroBg from '../assets/lifeguard-testing-day-28.avif';
import seaBg from '../assets/sea.avif';
import supportImg from '../assets/domi-tower-inauguration-2.avif';
import heroPhoto from '../assets/domi-tower-inauguration-50.webp';
import progVolunteer from '../assets/Volunteer.jpg';
import progJunior from '../assets/JuniorLifguard.png';
import progCommunity from '../assets/CommunityOutreach.png';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const c = copy[lang];
const routes = getRoutes(lang);
const donateHref = routes.donate;
const contactHref = routes.contact;

function parseUsdEnv(value: string | undefined, fallback: number): number {
	if (value === undefined || value === '') return fallback;
	const n = Number(value);
	return Number.isFinite(n) && n >= 0 ? n : fallback;
}

/** Mounts for Playa Hermosa (build-time). See `.env.example`. */
const playaHermosaRaised = parseUsdEnv(import.meta.env.PUBLIC_PLAYA_HERMOSA_RAISED, 60000);
const playaHermosaGoal = parseUsdEnv(import.meta.env.PUBLIC_PLAYA_HERMOSA_GOAL, 100000);
const playaHermosaPct =
	playaHermosaGoal > 0
		? Math.min(100, Math.max(0, Math.round((playaHermosaRaised / playaHermosaGoal) * 100)))
		: 0;

function formatReopenScaleUsd(usd: number): string {
	if (usd === 0) return '$0';
	if (usd >= 1_000_000) {
		const m = usd / 1_000_000;
		return Number.isInteger(m) ? `$${m}M` : `$${m.toFixed(1)}M`;
	}
	if (usd >= 1000) {
		const k = usd / 1000;
		return Number.isInteger(k) ? `$${k}k` : `$${k.toFixed(1)}k`;
	}
	return `$${usd}`;
}

const reopenScaleTicks = [0, 0.25, 0.5, 0.75, 1].map((f) => Math.round(playaHermosaGoal * f));
const raisedOfLabel = formatPlayaHermosaRaisedOf(lang, playaHermosaGoal);
const reopenAriaLabel =
	lang === 'es'
		? `Progreso de la campaña: ${playaHermosaPct}%`
		: `Campaign progress: ${playaHermosaPct}%`;
---

<main class="page-padding">
	<section class="hero">
		<img class="hero-bg" src={heroPhoto.src} alt="" fetchpriority="high" decoding="async" />
		<div class="hero-overlay" aria-hidden="true" />

		<div class="container hero-inner">
			<div class="hero-copy">
				<div class="kicker">{c.siteName}</div>
				<h1>{c.home.heroTitle}</h1>
				<p class="hero-sub">{c.home.heroSubtitle}</p>

				<div class="hero-actions">
					<a class="btn btn-accent hero-btn-sponsor" href={donateHref}>
						{c.home.sponsor}
					</a>
					<a class="btn btn-outline hero-btn-volunteer" href={contactHref}>
						{c.home.volunteer}
					</a>
				</div>

				<!-- ── Stats strip ───────────────────────── -->
				<div class="hero-stats" role="list">
				<div class="hero-stat" role="listitem">
					<span class="hero-stat-num">6,700+</span>
					<span class="hero-stat-label">{c.home.heroStatPreventions}</span>
				</div>
				<div class="hero-stat-divider" aria-hidden="true" />
				<div class="hero-stat" role="listitem">
					<span class="hero-stat-num">17</span>
					<span class="hero-stat-label">{c.home.heroStatRescues}</span>
				</div>
				<div class="hero-stat-divider" aria-hidden="true" />
				<div class="hero-stat" role="listitem">
					<span class="hero-stat-num">0</span>
					<span class="hero-stat-label">{c.home.heroStatOnDuty}</span>
				</div>
				</div>
			</div>
		</div>

		<!-- ── Wave transition (4 parallax layers via <use>) ─── -->
		<!--
			Un único <path> en <defs> reutilizado 4 veces con distintas
			opacidades y velocidades → paralaje más orgánico.
			GPU-composited: translateZ(0) + will-change + backface-visibility.
		-->
		<div class="hero-wave" aria-hidden="true">
			<svg
				class="waves-svg"
				xmlns="http://www.w3.org/2000/svg"
				xmlns:xlink="http://www.w3.org/1999/xlink"
				viewBox="0 21 150 30"
				preserveAspectRatio="none"
				shape-rendering="geometricPrecision"
			>
				<defs>
					<path
						id="gentle-wave"
						d="M-160 44c30 0 58-18 88-18s58 18 88 18 58-18 88-18 58 18 88 18v48h-352z"
					/>
				</defs>
				<g class="waves-parallax">
					<use xlink:href="#gentle-wave" x="48" y="0" fill="#00205b" fill-opacity="0.20"/>
					<use xlink:href="#gentle-wave" x="48" y="3" fill="#00205b" fill-opacity="0.42"/>
					<use xlink:href="#gentle-wave" x="48" y="5" fill="#00205b" fill-opacity="0.68"/>
					<use xlink:href="#gentle-wave" x="48" y="7" fill="#00205b"/>
				</g>
			</svg>
		</div>
	</section>

	<!-- ─── COMBINED: Reality → Support → Where ─────────────────── -->
	<!--
		Continuación directa de la ola del hero. Un solo bloque dark blue que:
		1. Establece la urgencia (Reality — 2 sentencias)
		2. Muestra exactamente qué hace posible el apoyo (4 glass cards)
		3. Genera confianza mostrando en qué se usa el dinero (Where + imagen)
	-->
	<section class="combined-section bg-base">
		<div class="container">

			<!-- ── PART 1: The Reality ───────────────────────────── -->
			<div class="cs-reality">
				<div class="cs-reality-kicker reveal">{c.home.realityTitle}</div>
				<p class="reality-heading reveal reveal-d1">{c.home.realityHeading}</p>
				<p class="reality-sub reveal reveal-d2">
					{c.home.realitySub}<em class="reality-accent">{c.home.realityAccent}</em>
				</p>
			</div>

			<div class="combined-sep" aria-hidden="true"></div>

			<!-- ── PART 2: What your support makes possible ─────── -->
			<div class="cs-support">
				<h2 class="h2 reveal" style="color: white; margin-bottom: 8px;">{c.home.supportTitle}</h2>
				<p class="muted reveal reveal-d1" style="max-width: 54ch;">{c.home.supportSubtitle}</p>
				<div class="support-cards-grid" style="margin-top: 32px;">
					<div class="support-card reveal reveal-d1">
						<div class="support-card-icon" aria-hidden="true">
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
								<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
							</svg>
						</div>
						<h3 class="support-card-title">{c.home.supportCards[0].title}</h3>
						<p class="support-card-desc">{c.home.supportCards[0].desc}</p>
					</div>
					<div class="support-card reveal reveal-d2">
						<div class="support-card-icon" aria-hidden="true">
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
								<circle cx="12" cy="12" r="10"/>
								<circle cx="12" cy="12" r="4"/>
								<line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/>
								<line x1="16.24" y1="16.24" x2="19.07" y2="19.07"/>
								<line x1="16.24" y1="7.76" x2="19.07" y2="4.93"/>
								<line x1="4.93" y1="19.07" x2="7.76" y2="16.24"/>
							</svg>
						</div>
						<h3 class="support-card-title">{c.home.supportCards[1].title}</h3>
						<p class="support-card-desc">{c.home.supportCards[1].desc}</p>
					</div>
					<div class="support-card reveal reveal-d3">
						<div class="support-card-icon" aria-hidden="true">
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
								<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
								<circle cx="9" cy="7" r="4"/>
								<path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
								<path d="M16 3.13a4 4 0 0 1 0 7.75"/>
							</svg>
						</div>
						<h3 class="support-card-title">{c.home.supportCards[2].title}</h3>
						<p class="support-card-desc">{c.home.supportCards[2].desc}</p>
					</div>
					<div class="support-card reveal reveal-d4">
						<div class="support-card-icon" aria-hidden="true">
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
								<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
								<path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
							</svg>
						</div>
						<h3 class="support-card-title">{c.home.supportCards[3].title}</h3>
						<p class="support-card-desc">{c.home.supportCards[3].desc}</p>
					</div>
				</div>
			</div>

	
		</div>
	</section>

	<!-- ─── WHERE YOUR MONEY GOES ────────────────────────────────── -->
	<!--
		Sección de transparencia — fondo claro para crear contraste
		visual tras las dos secciones oscuras (hero + combined).
		El blanco refuerza la sensación de confianza y apertura.
	-->
	<section class="where-section">
		<div class="container">
			<div class="two-col cs-where-grid">

				<!-- ── Text column ────────────────────────────── -->
				<div class="reveal-left">
					<div class="kicker">{c.home.transparencyKicker}</div>
					<h2 class="where-heading">
						{lang === 'es'
							? <><span>Así se usa</span> tu donación</>
							: <><span>Where your</span> money goes</>}
					</h2>
					<p class="where-intro">{c.home.whereIntro}</p>
					<ol class="where-num-list">
						{c.home.whereBullets.map((b, i) => (
							<li>
								<span class="where-num">{i + 1}</span>
								<span class="where-item-text">{b}</span>
							</li>
						))}
					</ol>
					<div class="where-trust">
						<!-- Shield icon -->
						<svg class="where-trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
						</svg>
						<p class="where-trust-text">{c.home.whereTrustText}</p>
					</div>
					<div style="margin-top: 28px;">
						<a class="btn btn-accent" href={donateHref}>{c.home.whereBtn}</a>
					</div>
				</div>

				<!-- ── Image column ───────────────────────────── -->
				<div class="where-img-wrap reveal-right">
					<img class="where-img" src={supportImg.src} alt="" loading="lazy" decoding="async" />
					<!-- Floating badge -->
					<div class="where-badge">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<polyline points="20 6 9 17 4 12"/>
						</svg>
						<div>
							<strong>{c.home.whereBadgeTitle}</strong>
							<span>{c.home.whereBadgeSub}</span>
						</div>
					</div>
				</div>

			</div>
		</div>
	</section>

	<!-- ─── PROGRAMS — accordion hover ──────────────────────────── -->
	<!--
		Dark blue para encadenar visualmente con la sección Impact.
		Patrón: lista numerada a la izquierda, imagen sticky a la derecha
		que cambia al hacer hover sobre cada programa.
	-->
	<section class="prog-section">
		<div class="container">

			<!-- Header -->
			<div class="prog-header reveal">
				<div class="prog-header-text">
					<div class="kicker">{c.home.programsTitle}</div>
					<h2 class="prog-title">{c.home.programsHeading}</h2>
				</div>
				<p class="prog-header-sub">{c.home.programsHeaderSub}</p>
			</div>

			<div class="prog-layout">

				<!-- ── Accordion list ─────────────────────────── -->
				<div class="prog-list" id="prog-list">

					{c.home.programs.map((prog, i) => (
						<div
							class={`prog-item${i === 0 ? ' is-active' : ''}`}
							data-index={i}
							role="button"
							tabindex="0"
							aria-label={prog.ariaLabel}
						>
							<div class="prog-divider"></div>
							<div class="prog-item-body">
								<div class="prog-meta">
									<span class="prog-num">{String(i + 1).padStart(2, '0')}</span>
								</div>
								<div class="prog-content">
									<h3 class="prog-name">
										{prog.name}
										<span class="prog-arrow" aria-hidden="true">→</span>
									</h3>
									<div class="prog-desc">
										<p>{prog.desc}</p>
									</div>
								</div>
							</div>
						</div>
					))}

					<!-- Bottom line -->
					<div class="prog-divider"></div>

					<!-- CTA -->
					<div class="prog-cta">
						<a class="btn btn-outline" href={contactHref}>{c.home.progCta}</a>
						<p class="prog-cta-note">{c.home.progCtaNote}</p>
					</div>
				</div>

				<!-- ── Image preview (sticky) ─────────────────── -->
				<div class="prog-preview" aria-hidden="true">
					<div class="prog-img-stack">
						<img class="prog-img is-active" data-index="0"
							src={progVolunteer.src} alt={c.home.programs[0].altText}
							loading="lazy" decoding="async" />
						<img class="prog-img" data-index="1"
							src={progJunior.src} alt={c.home.programs[1].altText}
							loading="lazy" decoding="async" />
						<img class="prog-img" data-index="2"
							src={progCommunity.src} alt={c.home.programs[2].altText}
							loading="lazy" decoding="async" />
					</div>
				</div>

			</div>
		</div>
	</section>

	<!-- ─── OUR IMPACT ──────────────────────────────────────────── -->
	<!--
		Narrativa de datos: prevenciones → rescates → 0 ahogamientos en servicio
		→ contraste off-duty. Cada bloque refuerza el mensaje de la misión.
		Datos: Logbook Reports April–December 2025.
	-->
	<section class="impact-section bg-base" id="impact-section">
		<div class="container">

			<!-- Header -->
			<div class="impact-header reveal">
				<div class="kicker">{c.home.impactKicker}</div>
				<h2 class="h2 impact-title">{c.home.impactTitle}</h2>
				<p class="impact-subtitle">{c.home.impactSubtitle}</p>
				<p class="impact-period">{c.home.impactPeriod}</p>
			</div>

			<!-- ── Prevention hero ───────────────────────────────── -->
			<div class="impact-prevention reveal">
				<div class="impact-prev-left">
					<div class="impact-big-num" data-count="6689" data-suffix="+">0</div>
				<div class="impact-big-label">{c.home.statPreventions}</div>
				<p class="impact-prev-note">{c.home.prevNote}</p>
				</div>
				<div class="impact-prev-bars">
					<div class="impact-bar-group">
						<div class="impact-bar-header">
							<span>Playa Hermosa</span>
							<strong>4,345</strong>
						</div>
						<div class="impact-bar-track">
							<div class="impact-bar-fill" style="--bar-w: 100%;"></div>
						</div>
					</div>
					<div class="impact-bar-group">
						<div class="impact-bar-header">
							<span>Playa Dominical</span>
							<strong>2,344</strong>
						</div>
						<div class="impact-bar-track">
							<div class="impact-bar-fill" style="--bar-w: 54%;"></div>
						</div>
					</div>
				</div>
			</div>

			<!-- ── 3-column metrics ──────────────────────────────── -->
			<div class="impact-metrics">
				<!-- Water Rescues -->
				<div class="impact-metric reveal reveal-d1">
					<div class="impact-metric-icon" aria-hidden="true">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/>
							<line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/>
							<line x1="16.24" y1="16.24" x2="19.07" y2="19.07"/>
							<line x1="16.24" y1="7.76" x2="19.07" y2="4.93"/>
							<line x1="4.93" y1="19.07" x2="7.76" y2="16.24"/>
						</svg>
					</div>
					<div class="impact-metric-num" data-count="17">0</div>
					<div class="impact-metric-label">{c.home.statRescues}</div>
					<div class="impact-metric-breakdown">
						{c.home.rescueBreakdown.map(r => (
							<span>{r.beach}: <strong>{r.count}</strong></span>
						))}
					</div>
				</div>

				<!-- Medical Assists -->
				<div class="impact-metric reveal reveal-d2">
					<div class="impact-metric-icon" aria-hidden="true">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
							<path d="M12 22C6.5 22 2 17.5 2 12S6.5 2 12 2s10 4.5 10 10-4.5 10-10 10z"/>
							<path d="M12 8v8M8 12h8"/>
						</svg>
					</div>
					<div class="impact-metric-num" data-count="15">0</div>
					<div class="impact-metric-label">{c.home.statMedical}</div>
					<div class="impact-metric-breakdown">
						{c.home.medicalBreakdown.map(r => (
							<span>{r.beach}: <strong>{r.count}</strong></span>
						))}
					</div>
				</div>

				<!-- Zero on-duty drownings — the key stat -->
				<div class="impact-metric impact-metric--zero reveal reveal-d3">
					<div class="impact-metric-icon impact-metric-icon--success" aria-hidden="true">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
							<polyline points="9 12 11 14 15 10"/>
						</svg>
					</div>
					<div class="impact-metric-zero">0</div>
					<div class="impact-metric-label">{c.home.statOnDuty}</div>
					<p class="impact-metric-zero-note">{c.home.onDutyNote}</p>
				</div>
			</div>

			<!-- ── Off-duty contrast ─────────────────────────────── -->
			<div class="impact-contrast reveal">
				<div class="impact-contrast-badge">{c.home.withoutOnDuty}</div>
				<div class="impact-contrast-body">
					<div class="impact-contrast-left">
						<div class="impact-contrast-num">8</div>
						<div class="impact-contrast-label">{c.home.statOffDuty}</div>
						<p class="impact-contrast-note">{c.home.offDutyNote}</p>
					</div>
					<div class="impact-contrast-right">
						<div class="impact-contrast-breakdown">
							{c.home.offDutyBreakdown.map(row => (
								<div class="impact-contrast-row">
									<span>{row.beach}</span>
									<strong>{row.count}</strong>
								</div>
							))}
						</div>
					</div>
				</div>
			</div>

		</div>
	</section>


	<!-- ─── HELP US REOPEN PLAYA HERMOSA ────────────────────────── -->
	<!--
		Urgencia concreta: campaña activa con progreso visible.
		El visitante ya entiende quiénes son y cómo ayudan → ahora se le presenta
		una necesidad específica.
	-->
	<section
		class="reopen"
		id="reopen-section"
		data-reopen-raised={playaHermosaRaised}
		data-reopen-pct={playaHermosaPct}
	>
		<img class="reopen-bg" src={heroBg.src} alt="" loading="lazy" decoding="async" />
		<div class="reopen-overlay" aria-hidden="true"></div>

		<div class="container reopen-inner">

			<!-- Left: narrative -->
			<div class="reopen-copy reveal">
				<div class="kicker reopen-kicker">{c.home.reopenKicker}</div>
				<h2 class="h2 reopen-title">{c.home.reopenTitle}</h2>
				<p class="reopen-body">{c.home.reopenBody}</p>

				<!-- Dominical success badge -->
				<div class="reopen-dominical">
					<span class="reopen-dominical-dot" aria-hidden="true"></span>
					<div>
						<strong>Playa Dominical</strong>
						<span>{c.home.domFunded}</span>
					</div>
				</div>

				<a class="btn btn-primary reopen-cta" href={donateHref}>
					{c.home.reopenCta}
				</a>
			</div>

			<!-- Right: campaign card -->
			<div class="reopen-card reveal reveal-d2">
				<div class="reopen-card-header">
					<div class="reopen-card-beach">Playa Hermosa</div>
					<div class="reopen-card-status">
						<span class="reopen-card-status-dot" aria-hidden="true"></span>
						{c.home.cardInProgress}
					</div>
				</div>

				<div class="reopen-amount-row">
					<div>
						<div class="reopen-amount" id="reopen-amount">$0</div>
						<div class="reopen-amount-label">{raisedOfLabel}</div>
					</div>
					<div class="reopen-pct" id="reopen-pct">0%</div>
				</div>

				<!-- Progress bar -->
				<div
					class="reopen-bar-track"
					role="progressbar"
					aria-valuenow={playaHermosaPct}
					aria-valuemin="0"
					aria-valuemax="100"
					aria-label={reopenAriaLabel}
				>
					<div
						class="reopen-bar-fill"
						id="reopen-bar"
						style={`--reopen-fill-pct: ${playaHermosaPct}%;`}
					></div>
					<div class="reopen-bar-marker" style="left: 50%;" aria-hidden="true">
						<span class="reopen-bar-marker-label">3 {c.home.monthsShort}</span>
					</div>
