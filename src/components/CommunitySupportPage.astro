---
import { copy, type Lang } from '../i18n/copy';
import { getRoutes } from '../i18n/routes';
import { sponsorLogos } from '../data/sponsorLogos';
import { sponsorLogosPlayaHermosa } from '../data/sponsorLogosPlayaHermosa';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const c = copy[lang];
const p = c.pages;
const routes = getRoutes(lang);

const nameKey = lang === 'es' ? 'nameEs' : 'nameEn';
const altSuffix = lang === 'es' ? 'logo de aliado' : 'partner logo';
const logos = sponsorLogos.map((s) => {
	const name = s[nameKey];
	return {
		href: s.href,
		alt: `${name} — ${altSuffix}`,
		name,
	};
});
const logosHermosa = sponsorLogosPlayaHermosa.map((s) => {
	const name = s[nameKey];
	return {
		href: s.href,
		alt: `${name} — ${altSuffix}`,
		name,
	};
});

const fuelParas = p.communityFuelParagraphs;
const hermosaParas = p.communityHermosaParagraphs;

const nav = c.nav;
---

<main class="community-page">
	<section class="community-hero" aria-labelledby="community-hero-title">
		<div class="community-hero-bg" aria-hidden="true">
			<span class="community-orb community-orb--1"></span>
			<span class="community-orb community-orb--2"></span>
			<span class="community-orb community-orb--3"></span>
			<span class="community-hero-mesh" aria-hidden="true"></span>
		</div>
		<div class="community-hero-waves" aria-hidden="true">
			<svg class="community-wave community-wave--top" viewBox="0 0 1440 100" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
				<path fill="rgba(42, 118, 181, 0.08)" d="M0 100V48Q360 8 720 52T1440 38V100H0z"></path>
			</svg>
		</div>
		<div class="container community-hero-inner">
			<p class="kicker community-kicker reveal">{p.communityKicker}</p>
			<h1 id="community-hero-title" class="community-hero-title reveal reveal-d1">{p.communityHeroTitle}</h1>
			<div class="community-hero-rule reveal reveal-d1" aria-hidden="true"></div>
			<div class="community-fuel-copy">
				{
					fuelParas.map((para, i) => (
						<p class={`community-fuel-p reveal reveal-d${Math.min(i + 2, 6)}`}>{para}</p>
					))
				}
			</div>
		</div>
		<div class="community-hero-bottom-wave" aria-hidden="true">
			<svg class="community-wave community-wave--bottom" viewBox="0 0 1440 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
				<path
					fill="url(#community-hero-wave-grad)"
					d="M0 0v46c240 52 480 28 720 38s480-18 720 22v14H0z"
				></path>
				<defs>
					<linearGradient id="community-hero-wave-grad" x1="0%" y1="0%" x2="0%" y2="100%">
						<stop offset="0%" stop-color="rgba(42, 118, 181, 0.14)"></stop>
						<stop offset="100%" stop-color="rgba(255, 255, 255, 0.95)"></stop>
					</linearGradient>
				</defs>
			</svg>
		</div>
	</section>

	<section class="community-marquee-section" aria-labelledby="marquee-heading">
		<div class="container">
			<h2 id="marquee-heading" class="community-section-label reveal">{p.communityMarqueeLabel}</h2>
		</div>
		<div class="community-marquee" role="region" aria-label={p.communityMarqueeAria}>
			<div class="community-marquee-fade community-marquee-fade--left" aria-hidden="true"></div>
			<div class="community-marquee-fade community-marquee-fade--right" aria-hidden="true"></div>
			<div class="community-marquee-track community-marquee-track--a">
				{
					[0, 1].flatMap((dup) =>
						logos.map((logo, i) => (
							<div class="community-marquee-item">
								<div class="community-marquee-chip">
									<img
										src={logo.href}
										alt=""
										class="community-marquee-img"
										width={280}
										height={72}
										loading={dup === 0 && i < 3 ? 'eager' : 'lazy'}
										decoding="async"
									/>
								</div>
							</div>
						))
					)
				}
			</div>
		</div>
		<div class="community-marquee community-marquee--b" aria-hidden="true">
			<div class="community-marquee-fade community-marquee-fade--left" aria-hidden="true"></div>
			<div class="community-marquee-fade community-marquee-fade--right" aria-hidden="true"></div>
			<div class="community-marquee-track community-marquee-track--b">
				{
					[0, 1].flatMap(() =>
						[...logos].reverse().map((logo) => (
							<div class="community-marquee-item">
								<div class="community-marquee-chip">
									<img
										src={logo.href}
										alt=""
										class="community-marquee-img"
										width={280}
										height={72}
										loading="lazy"
										decoding="async"
									/>
								</div>
							</div>
						))
					)
				}
			</div>
		</div>
	</section>

	<section class="community-grid-section" aria-labelledby="grid-heading">
		<div class="container">
			<h2 id="grid-heading" class="community-grid-title reveal">{p.communityGridTitle}</h2>
			<ul class="community-grid">
				{
					logos.map((logo, index) => (
						<li
							class={`community-card reveal reveal-d${(index % 6) + 1}`}
							style={`--i:${index}`}
						>
							<div class="community-card-inner">
								<div class="community-card-shine" aria-hidden="true"></div>
								<div class="community-card-frame">
									<img
										src={logo.href}
										alt={logo.alt}
										class="community-card-img"
										width={320}
										height={120}
										loading="lazy"
										decoding="async"
									/>
								</div>
								<p class="community-card-name">{logo.name}</p>
							</div>
						</li>
					))
				}
			</ul>
		</div>
	</section>

	<section class="community-hermosa-band" aria-labelledby="hermosa-heading">
		<div class="community-hermosa-bg" aria-hidden="true"></div>
		<div class="container community-hermosa-intro">
			<h2 id="hermosa-heading" class="community-hermosa-title reveal">{p.communityHermosaTitle}</h2>
			<div class="community-hermosa-rule reveal" aria-hidden="true"></div>
			{
				hermosaParas.map((para, i) => (
					<p class={`community-hermosa-p reveal reveal-d${i + 1}`}>{para}</p>
				))
			}
		</div>

		<div class="community-marquee-section community-marquee-section--hermosa">
			<div class="container">
				<h3 class="community-section-label community-section-label--hermosa reveal">{p.communityHermosaMarqueeLabel}</h3>
			</div>
			<div class="community-marquee community-marquee--hermosa" role="region" aria-label={p.communityHermosaMarqueeAria}>
				<div class="community-marquee-fade community-marquee-fade--left community-marquee-fade--hermosa" aria-hidden="true"></div>
				<div class="community-marquee-fade community-marquee-fade--right community-marquee-fade--hermosa" aria-hidden="true"></div>
				<div class="community-marquee-track community-marquee-track--a community-marquee-track--hermosa">
					{
						[0, 1].flatMap((dup) =>
							logosHermosa.map((logo, i) => (
								<div class="community-marquee-item">
									<div class="community-marquee-chip community-marquee-chip--hermosa">
										<img
											src={logo.href}
											alt=""
											class="community-marquee-img"
											width={280}
											height={72}
											loading={dup === 0 && i < 3 ? 'eager' : 'lazy'}
											decoding="async"
										/>
									</div>
								</div>
							))
						)
					}
				</div>
			</div>
			<div class="community-marquee community-marquee--b community-marquee--hermosa-b" aria-hidden="true">
				<div class="community-marquee-fade community-marquee-fade--left community-marquee-fade--hermosa" aria-hidden="true"></div>
				<div class="community-marquee-fade community-marquee-fade--right community-marquee-fade--hermosa" aria-hidden="true"></div>
				<div class="community-marquee-track community-marquee-track--b community-marquee-track--hermosa">
					{
						[0, 1].flatMap(() =>
							[...logosHermosa].reverse().map((logo) => (
								<div class="community-marquee-item">
									<div class="community-marquee-chip community-marquee-chip--hermosa">
										<img
											src={logo.href}
											alt=""
											class="community-marquee-img"
											width={280}
											height={72}
											loading="lazy"
											decoding="async"
										/>
									</div>
								</div>
							))
						)
					}
				</div>
			</div>
		</div>

		<div class="container community-grid-section community-grid-section--hermosa">
			<h3 id="hermosa-grid-heading" class="community-grid-title community-grid-title--hermosa reveal">
				{p.communityHermosaGridTitle}
			</h3>
			<ul class="community-grid" aria-labelledby="hermosa-grid-heading">
				{
					logosHermosa.map((logo, index) => (
						<li
							class={`community-card community-card--hermosa reveal reveal-d${(index % 6) + 1}`}
							style={`--i:${index}`}
						>
							<div class="community-card-inner community-card-inner--hermosa">
								<div class="community-card-shine" aria-hidden="true"></div>
								<div class="community-card-frame">
									<img
										src={logo.href}
										alt={logo.alt}
										class="community-card-img"
										width={320}
										height={120}
										loading="lazy"
										decoding="async"
									/>
								</div>
								<p class="community-card-name">{logo.name}</p>
							</div>
						</li>
					))
				}
			</ul>
		</div>
	</section>

	<section class="community-cta-section" aria-labelledby="cta-heading">
		<div class="container community-cta-wrap">
			<div class="community-cta reveal reveal-scale">
				<div class="community-cta-glow" aria-hidden="true"></div>
				<h2 id="cta-heading" class="community-cta-title">{p.communityCtaTitle}</h2>
				<p class="community-cta-body">{p.communityCtaBody}</p>
				<div class="community-cta-actions">
					<a class="btn btn-primary community-cta-btn" href={routes.donate}>
						{p.communityCtaBtn}
						<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" class="community-cta-arrow" aria-hidden="true">
							<path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"></path>
						</svg>
					</a>
					<a class="btn btn-outline community-cta-secondary" href={routes.contact}>{nav.contact}</a>
				</div>
			</div>
		</div>
	</section>
</main>

<style>
	.community-page {
		overflow-x: hidden;
	}

	/* ── Hero ─────────────────────────────────────────────── */
	.community-hero {
		position: relative;
		padding: clamp(32px, 6vw, 56px) 0 clamp(40px, 7vw, 64px);
		overflow: hidden;
	}

	.community-hero-bg {
		position: absolute;
		inset: 0;
		overflow: hidden;
		background:
			radial-gradient(ellipse 90% 55% at 15% 8%, rgba(42, 118, 181, 0.2), transparent 52%),
			radial-gradient(ellipse 70% 45% at 88% 25%, rgba(237, 67, 76, 0.1), transparent 48%),
			radial-gradient(ellipse 50% 40% at 50% 95%, rgba(0, 32, 91, 0.06), transparent 50%),
			linear-gradient(168deg, #e4eef9 0%, #f5f9ff 38%, #ffffff 72%);
		pointer-events: none;
	}

	.community-hero-mesh {
		position: absolute;
		inset: -30% -20%;
		opacity: 0.4;
		background-image:
			linear-gradient(rgba(0, 32, 91, 0.035) 1px, transparent 1px),
			linear-gradient(90deg, rgba(0, 32, 91, 0.035) 1px, transparent 1px);
		background-size: 40px 40px;
		mask-image: radial-gradient(ellipse 65% 55% at 50% 35%, black 0%, transparent 75%);
		-webkit-mask-image: radial-gradient(ellipse 65% 55% at 50% 35%, black 0%, transparent 75%);
	}

	.community-orb {
		position: absolute;
		border-radius: 50%;
		filter: blur(56px);
		pointer-events: none;
		opacity: 0.85;
	}

	.community-orb--1 {
		width: min(380px, 50vw);
		height: min(380px, 50vw);
		top: -12%;
		left: -8%;
		background: radial-gradient(circle at 35% 35%, rgba(120, 180, 230, 0.45), rgba(42, 118, 181, 0.12) 55%, transparent 72%);
	}

	.community-orb--2 {
		width: min(320px, 42vw);
		height: min(320px, 42vw);
		top: 28%;
		right: -10%;
		background: radial-gradient(circle at 50% 50%, rgba(0, 32, 91, 0.18), transparent 68%);
	}

	.community-orb--3 {
		width: min(220px, 30vw);
		height: min(220px, 30vw);
		bottom: 8%;
		left: 35%;
		background: radial-gradient(circle at 50% 50%, rgba(237, 67, 76, 0.22), transparent 65%);
	}

	@media (prefers-reduced-motion: reduce) {
		.community-orb {
			opacity: 0.45;
			filter: blur(40px);
		}
	}

	.community-hero-waves {
		position: absolute;
		left: -10%;
		right: -10%;
		top: 0;
		height: min(20vh, 160px);
		opacity: 0.85;
		pointer-events: none;
	}

	.community-wave {
		width: 100%;
		height: 100%;
		display: block;
	}

	@media (prefers-reduced-motion: no-preference) {
		.community-wave--top {
			animation: community-wave-float 22s ease-in-out infinite alternate;
		}
	}

	@keyframes community-wave-float {
		from {
			transform: translateX(-2%);
		}
		to {
			transform: translateX(2%);
		}
	}

	.community-hero-inner {
		position: relative;
		z-index: 1;
		max-width: 720px;
		margin: 0 auto;
		text-align: center;
	}

	.community-kicker {
		margin-bottom: 12px;
	}

	.community-hero-title {
		margin: 0 0 14px;
		font-size: clamp(2rem, 5vw, 2.75rem);
		font-weight: 800;
		letter-spacing: -0.03em;
		line-height: 1.12;
		color: var(--color-base);
		text-shadow: 0 1px 0 rgba(255, 255, 255, 0.85);
	}

	.community-hero-rule {
		width: 72px;
		height: 5px;
		margin: 0 auto 22px;
		border-radius: 999px;
		background: linear-gradient(90deg, var(--color-accent) 0%, var(--color-accent-400) 35%, var(--color-primary) 100%);
		box-shadow: 0 2px 12px rgba(237, 67, 76, 0.25);
	}

	.community-fuel-copy {
		text-align: left;
		max-width: 58ch;
		margin: 0 auto;
	}

	.community-fuel-p {
		margin: 0 0 14px;
		font-size: 15px;
		line-height: 1.72;
		color: var(--color-text);
		font-weight: 500;
	}

	.community-fuel-p:last-child {
		margin-bottom: 0;
	}

	.community-fuel-p:first-of-type {
		font-size: clamp(1.02rem, 2.1vw, 1.12rem);
		font-weight: 600;
		color: var(--color-base);
	}

	.community-hero-bottom-wave {
		position: relative;
		z-index: 0;
		margin-top: -1px;
		line-height: 0;
	}

	.community-wave--bottom {
		width: 100%;
		height: clamp(56px, 10vw, 88px);
		display: block;
	}

	/* ── Playa Hermosa band ───────────────────────────────── */
	.community-hermosa-band {
		position: relative;
		padding-bottom: 8px;
		overflow: hidden;
	}

	.community-hermosa-bg {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(ellipse 60% 50% at 50% 0%, rgba(237, 67, 76, 0.07), transparent 55%),
			linear-gradient(180deg, #fff9f6 0%, #f3f7fc 38%, #fafcff 100%);
		pointer-events: none;
	}

	.community-hermosa-intro {
		position: relative;
		z-index: 1;
		max-width: 720px;
		margin: 0 auto;
		/* Use padding-block only so .container horizontal padding is not reset */
		padding-top: 40px;
		padding-bottom: 12px;
		text-align: center;
	}

	.community-hermosa-title {
		margin: 0 0 12px;
		font-size: clamp(1.65rem, 4vw, 2.1rem);
		font-weight: 800;
		letter-spacing: -0.03em;
		color: var(--color-base);
	}

	.community-hermosa-rule {
		width: 48px;
		height: 3px;
		margin: 0 auto 18px;
		border-radius: 3px;
		background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
		opacity: 0.9;
	}

	.community-hermosa-p {
		margin: 0 0 14px;
		font-size: 15px;
		line-height: 1.72;
		color: var(--color-muted);
		font-weight: 500;
		text-align: left;
		max-width: 58ch;
		margin-left: auto;
		margin-right: auto;
	}

	.community-hermosa-p:last-of-type {
		margin-bottom: 0;
		font-style: italic;
		color: var(--color-text);
	}

	.community-section-label--hermosa {
		color: #7a2a32;
		opacity: 0.95;
		background: linear-gradient(165deg, #ffffff 0%, #fff5f3 100%);
		border-color: rgba(237, 67, 76, 0.22);
		box-shadow:
			0 4px 16px rgba(122, 42, 50, 0.07),
			0 0 0 1px rgba(255, 255, 255, 0.95) inset;
	}

	.community-marquee-section--hermosa {
		background: transparent;
		padding-top: 0;
	}

	.community-marquee-fade--hermosa.community-marquee-fade--left {
		background: linear-gradient(90deg, #f7f9fc, transparent);
	}

	.community-marquee-fade--hermosa.community-marquee-fade--right {
		background: linear-gradient(270deg, #f7f9fc, transparent);
	}

	.community-grid-section--hermosa {
		padding-top: 28px;
		padding-bottom: 44px;
		background: transparent;
		position: relative;
		z-index: 1;
	}

	.community-grid-title--hermosa {
		color: var(--color-base);
		background: linear-gradient(90deg, transparent, rgba(237, 67, 76, 0.2), transparent) bottom / 120px 3px no-repeat;
	}

	/* ── Marquee ─────────────────────────────────────────── */
	.community-marquee-section {
		position: relative;
		padding: 12px 0 32px;
		background:
			radial-gradient(ellipse 80% 90% at 50% 0%, rgba(42, 118, 181, 0.06), transparent 55%),
			linear-gradient(185deg, #ffffff 0%, #eef4fc 42%, #f7faff 100%);
	}

	.community-marquee-section::before {
		content: '';
		position: absolute;
		left: 50%;
		top: 0;
		transform: translateX(-50%);
		width: min(92%, 880px);
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(42, 118, 181, 0.22), transparent);
		pointer-events: none;
	}

	.community-section-label {
		margin: 0 auto 22px;
		display: table;
		padding: 10px 18px;
		font-size: 11px;
		font-weight: 800;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--color-primary-600);
		text-align: center;
		border-radius: 999px;
		background: linear-gradient(165deg, rgba(255, 255, 255, 0.95) 0%, rgba(232, 242, 252, 0.98) 100%);
		border: 1px solid rgba(42, 118, 181, 0.18);
		box-shadow:
			0 4px 16px rgba(0, 32, 91, 0.06),
			0 0 0 1px rgba(255, 255, 255, 0.9) inset;
	}

	.community-marquee {
		position: relative;
		overflow: hidden;
		padding: 12px 0;
		mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
	}

	.community-marquee--b {
		margin-top: 4px;
		opacity: 0.92;
	}

	.community-marquee-fade {
		position: absolute;
		top: 0;
		bottom: 0;
		width: 48px;
		z-index: 2;
		pointer-events: none;
	}

	.community-marquee-fade--left {
		left: 0;
		background: linear-gradient(90deg, #eef4fc, transparent);
	}

	.community-marquee-fade--right {
		right: 0;
		background: linear-gradient(270deg, #eef4fc, transparent);
	}

	.community-marquee-track {
		display: flex;
		width: max-content;
		gap: clamp(28px, 4vw, 48px);
		align-items: center;
	}

	.community-marquee-track--a {
		animation: community-marquee-scroll 45s linear infinite;
	}

	.community-marquee-track--b {
		animation: community-marquee-scroll 52s linear infinite reverse;
	}

	@media (prefers-reduced-motion: reduce) {
		.community-marquee-track--a,
		.community-marquee-track--b {
			animation: none;
			flex-wrap: wrap;
			justify-content: center;
			width: 100%;
			max-width: 960px;
			margin: 0 auto;
			padding: 0 16px;
		}

		.community-marquee {
			mask-image: none;
		}
	}

	@keyframes community-marquee-scroll {
		from {
			transform: translateX(0);
		}
		to {
			transform: translateX(-50%);
		}
	}

	.community-marquee-item {
		flex-shrink: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		height: 84px;
		width: 168px;
	}

	.community-marquee-chip {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		height: 100%;
		min-height: 76px;
		padding: 10px 14px;
		border-radius: 20px 24px 22px 26px;
		background: linear-gradient(155deg, #ffffff 0%, #f3f7fd 55%, #ffffff 100%);
		border: 1px solid rgba(255, 255, 255, 0.95);
		box-shadow:
			0 2px 4px rgba(0, 32, 91, 0.04),
			0 10px 28px rgba(0, 32, 91, 0.07),
			0 0 0 1px rgba(0, 32, 91, 0.05) inset;
		transition:
			transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
