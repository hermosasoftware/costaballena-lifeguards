	/* Capa océano / olas — envuelve Membership + How to Donate */
	.donate-band-decor {
		position: absolute;
		inset: 0;
		z-index: 0;
		pointer-events: none;
		overflow: hidden;
	}

	.donate-band-decor__mesh {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(ellipse 65% 50% at 10% 18%, rgba(42, 118, 181, 0.16), transparent 58%),
			radial-gradient(ellipse 50% 45% at 92% 12%, rgba(237, 67, 76, 0.08), transparent 52%),
			radial-gradient(ellipse 55% 40% at 48% 88%, rgba(0, 32, 91, 0.06), transparent 55%),
			radial-gradient(ellipse 35% 30% at 72% 45%, rgba(42, 118, 181, 0.05), transparent 50%);
	}

	.donate-band-decor__top {
		position: absolute;
		left: -8%;
		right: -8%;
		top: 0;
		height: min(22vh, 180px);
		line-height: 0;
		opacity: 0.95;
	}

	.donate-band-decor__top svg {
		width: 100%;
		height: 100%;
		display: block;
	}

	.donate-band-decor__bottom {
		position: absolute;
		left: -12%;
		right: -12%;
		bottom: 0;
		height: min(46vh, 340px);
		line-height: 0;
	}

	.donate-band-decor__bottom .donate-band-decor__svg {
		position: absolute;
		left: 0;
		bottom: 0;
		width: 100%;
		height: auto;
		min-height: 100px;
		display: block;
	}

	.donate-band-decor__svg--b2 {
		z-index: 0;
		opacity: 0.92;
	}

	.donate-band-decor__svg--b1 {
		z-index: 1;
		bottom: -6px;
		opacity: 1;
	}

	@media (prefers-reduced-motion: no-preference) {
		.donate-band-decor__svg--top {
			animation: donate-wave-shift 26s ease-in-out infinite alternate;
		}

		.donate-band-decor__svg--b1 {
			animation: donate-wave-shift 20s ease-in-out infinite alternate-reverse;
		}

		.donate-band-decor__svg--b2 {
			animation: donate-wave-drift 24s ease-in-out infinite alternate;
		}
	}

	@keyframes donate-wave-shift {
		from {
			transform: translateX(-2.5%);
		}
		to {
			transform: translateX(2.5%);
		}
	}

	@keyframes donate-wave-drift {
		from {
			transform: translateX(-1.5%) scaleY(1);
		}
		to {
			transform: translateX(3%) scaleY(1.03);
		}
	}

