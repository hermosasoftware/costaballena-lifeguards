---
import { copy, type Lang } from '../i18n/copy';
import { getRoutes } from '../i18n/routes';
import TiersSection from './TiersSection.astro';
import eventImg from '../assets/domi-tower-inauguration-48.webp';
import iconUsers from '../assets/users.svg?url';
import iconStore from '../assets/store.svg?url';
import iconHeart from '../assets/heart.svg?url';
import iconHandHeart from '../assets/hand-heart.svg?url';
import iconUserCheck from '../assets/user-check.svg?url';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const c = copy[lang];
const d = c.donate;
const routes = getRoutes(lang);
const contactHref = routes.contact;

/** Order matches introFundedList: community, businesses, donors, supporters, volunteers */
const supporterIconSrc = [iconUsers, iconStore, iconHeart, iconHandHeart, iconUserCheck] as const;

---

<main class="page-padding">

	<!-- ─── INTRO HERO ────────────────────────────────────────── -->
	<section class="donate-intro-hero section" aria-labelledby="donate-page-title">
		<div class="donate-intro-hero-accent" aria-hidden="true"></div>
		<div class="container donate-intro-hero-inner">
			<div class="donate-intro-copy">
				<div class="donate-intro-kicker-row">
					<span class="kicker">{c.siteName}</span>
				</div>
				<h1 id="donate-page-title" class="donate-intro-title">{d.pageTitle}</h1>
				<p class="donate-intro-lead">{d.introLead}</p>

				<div class="donate-intro-funding">
					<p class="donate-intro-body">{d.introBody}</p>
				</div>

				<ul class="donate-intro-supporters" aria-label={d.introSupportersTitle}>
					{d.introFundedList.map((item, i) => (
						<li class="donate-intro-supporter-card">
							<span class="donate-intro-supporter-icon" aria-hidden="true">
								<img
									class="donate-intro-supporter-img"
									src={supporterIconSrc[i]}
									alt=""
									width="24"
									height="24"
									loading="lazy"
									decoding="async"
								/>
							</span>
							<span class="donate-intro-supporter-text">{item}</span>
						</li>
					))}
				</ul>

				<blockquote class="donate-intro-quote">
					<p>{d.introClosing}</p>
				</blockquote>

				<div class="donate-intro-ctas">
					<a class="btn btn-accent donate-intro-cta-main" href="#donate-methods">{d.introCtaPrimary}</a>
					<a class="btn btn-outline donate-intro-cta-sub" href="#tiers-section">{d.introCtaSecondary}</a>
				</div>
				<p class="donate-intro-hint">{d.introMethodHint}</p>
			</div>

			<figure class="donate-intro-visual">
				<div class="donate-intro-frame">
					<img
						src={eventImg.src}
						alt={d.introImageAlt}
						class="donate-intro-img"
						loading="lazy"
						decoding="async"
						width="560"
						height="700"
					/>
					<div class="donate-intro-img-shine" aria-hidden="true"></div>
				</div>
				<figcaption class="donate-intro-caption">
					<span class="donate-intro-caption-dot" aria-hidden="true"></span>
					{d.introImageCaption}
				</figcaption>
			</figure>
		</div>
	</section>

	<!-- ─── TIERS ─────────────────────────────────────────────── -->
	<TiersSection lang={lang} ctaHref={d.methodUsLink} />

	<!-- ─── MEMBERSHIP + HOW TO DONATE (banda clara unificada, sin zebra) ─── -->
	<div class="donate-light-band">
		<div class="donate-band-decor" aria-hidden="true">
			<div class="donate-band-decor__mesh"></div>
			<div class="donate-band-decor__top">
				<svg
					class="donate-band-decor__svg donate-band-decor__svg--top"
					viewBox="0 0 1440 120"
					preserveAspectRatio="none"
					xmlns="http://www.w3.org/2000/svg"
					focusable="false"
				>
					<path
						fill="rgba(42, 118, 181, 0.1)"
						d="M0 120V55 Q360 8 720 48 T1440 38V120H0z"
					/>
				</svg>
			</div>
			<div class="donate-band-decor__bottom">
				<svg
					class="donate-band-decor__svg donate-band-decor__svg--b2"
					viewBox="0 0 1440 220"
					preserveAspectRatio="none"
					xmlns="http://www.w3.org/2000/svg"
					focusable="false"
				>
					<path
						fill="rgba(0, 32, 91, 0.08)"
						d="M0 155 Q240 95 480 125 T960 105 T1440 135V220H0z"
					/>
				</svg>
				<svg
					class="donate-band-decor__svg donate-band-decor__svg--b1"
					viewBox="0 0 1440 200"
					preserveAspectRatio="none"
					xmlns="http://www.w3.org/2000/svg"
					focusable="false"
				>
					<path
						fill="rgba(42, 118, 181, 0.12)"
						d="M0 110 Q320 45 640 85 T1280 65 T1440 90V200H0z"
					/>
				</svg>
			</div>
			<div class="donate-band-decor__noise"></div>
		</div>
		<section class="section membership-section" aria-labelledby="membership-heading">
			<div class="container">
				<div class="membership-ambient" aria-hidden="true"></div>
				<div class="membership-wrap">
					<header class="membership-hero reveal">
						<p class="kicker membership-kicker-centered">{d.membershipKicker}</p>
						<h2 id="membership-heading" class="h2 membership-title-xl">{d.membershipTitle}</h2>
						<div class="membership-title-rule" aria-hidden="true"></div>
					</header>

					<div class="membership-grid-top">
						<article class="membership-tier-card reveal reveal-d1">
							<div class="membership-tier-shine" aria-hidden="true"></div>
							<div class="membership-tier-icon membership-tier-icon--annual" aria-hidden="true">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
									<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
									<line x1="16" y1="2" x2="16" y2="6"/>
									<line x1="8" y1="2" x2="8" y2="6"/>
									<line x1="3" y1="10" x2="21" y2="10"/>
								</svg>
							</div>
							<h3 class="membership-tier-name">{d.membershipAnnualTitle}</h3>
							<p class="membership-tier-desc">{d.membershipLine1}</p>
						</article>
						<article class="membership-tier-card reveal reveal-d2">
							<div class="membership-tier-shine" aria-hidden="true"></div>
							<div class="membership-tier-icon membership-tier-icon--monthly" aria-hidden="true">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="12" cy="12" r="10"/>
									<polyline points="12 6 12 12 16 14"/>
								</svg>
							</div>
							<h3 class="membership-tier-name">{d.membershipMonthlyTitle}</h3>
							<p class="membership-tier-desc">{d.membershipLine2}</p>
						</article>
					</div>

					<p class="membership-bridge reveal reveal-d3">
						<span class="membership-bridge-line" aria-hidden="true"></span>
						<em class="membership-bridge-text">{d.membershipLine3}</em>
						<span class="membership-bridge-line" aria-hidden="true"></span>
					</p>

					<div class="membership-grid-bottom">
						<article class="membership-spotlight membership-spotlight--tax reveal reveal-d1">
							<div class="membership-spotlight-icon" aria-hidden="true">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round">
									<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
									<polyline points="9 12 11 14 15 10"/>
								</svg>
							</div>
							<div class="membership-spotlight-textwrap">
								<h3 class="membership-spotlight-title">{d.membershipTaxCardTitle}</h3>
								<p class="membership-spotlight-text">{d.membershipTaxNote}</p>
							</div>
						</article>
						<article class="membership-spotlight membership-spotlight--angel reveal reveal-d2">
							<div class="membership-spotlight-icon membership-spotlight-icon--angel" aria-hidden="true">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.65" stroke-linecap="round" stroke-linejoin="round">
									<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
								</svg>
							</div>
							<div class="membership-spotlight-textwrap">
								<h3 class="membership-spotlight-title">{d.membershipAngelCardTitle}</h3>
								<p class="membership-spotlight-text">{d.membershipAngelNote}</p>
							</div>
						</article>
					</div>

					<div class="membership-every reveal reveal-scale">
						<div class="membership-every-blob" aria-hidden="true"></div>
						<div class="membership-every-inner">
							<img
								class="membership-every-heart"
								src={iconHeart}
								alt=""
								width="40"
								height="40"
								loading="lazy"
								decoding="async"
							/>
							<p class="membership-every-text">{d.membershipEvery}</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<div class="donate-band-divider" aria-hidden="true"></div>

		<section class="section how-section" id="donate-methods" aria-labelledby="how-heading">
			<div class="how-ambient" aria-hidden="true"></div>
			<div class="container">
				<header class="how-header reveal">
					<p class="kicker how-kicker">{d.howKicker}</p>
					<h2 id="how-heading" class="h2 how-title">{d.howTitle}</h2>
					<div class="how-title-rule" aria-hidden="true"></div>
					<p class="how-sub">{d.howSubtitle}</p>
				</header>

				<div class="methods-grid">
					<!-- U.S. Tax-Deductible -->
					<article class="method-card reveal reveal-d1">
						<div class="method-card-shine" aria-hidden="true"></div>
						<div class="method-card-top">
							<div class="method-icon method-icon--us" aria-hidden="true">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="12" cy="12" r="10"/>
									<path d="M12 6v6l4 2"/>
								</svg>
							</div>
							<h3 class="method-title">{d.methodUsTitle}</h3>
						</div>
						<p class="method-body">{d.methodUsBody}</p>
						<div class="method-card-footer">
							<a
								class="btn btn-primary method-btn"
								href={d.methodUsLink}
								target="_blank"
								rel="noopener noreferrer"
							>
								{d.methodUsBtn}
								<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="method-btn-arrow">
									<path d="M3 8h10M9 4l4 4-4 4"/>
								</svg>
							</a>
						</div>
					</article>

					<!-- PayPal -->
					<article class="method-card reveal reveal-d2">
						<div class="method-card-shine" aria-hidden="true"></div>
						<div class="method-card-top">
							<div class="method-icon method-icon--paypal" aria-hidden="true">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
									<rect x="2" y="5" width="20" height="14" rx="3"/>
									<path d="M2 10h20"/>
								</svg>
							</div>
							<h3 class="method-title">{d.methodPaypalTitle}</h3>
						</div>
						<p class="method-body">{d.methodPaypalBody}</p>
						<div class="method-card-footer">
							<a
								class="btn btn-primary method-btn"
								href={d.methodPaypalLink}
								target="_blank"
								rel="noopener noreferrer"
							>
								{d.methodPaypalBtn}
								<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="method-btn-arrow">
									<path d="M3 8h10M9 4l4 4-4 4"/>
								</svg>
							</a>
						</div>
					</article>

					<!-- Bank Transfer -->
					<article class="method-card method-card--bank reveal reveal-d3">
						<div class="method-card-shine" aria-hidden="true"></div>
						<div class="method-card-top">
							<div class="method-icon method-icon--bank" aria-hidden="true">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
									<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
									<polyline points="9 22 9 12 15 12 15 22"/>
								</svg>
							</div>
							<h3 class="method-title">{d.methodBankTitle}</h3>
						</div>
						<div class="method-bank-meta">
							<p class="bank-line bank-name">{d.methodBankAccountName}</p>
							<p class="bank-line muted">{d.methodBankCedula}</p>
						</div>

						<div class="bank-accounts">
							<div class="bank-account">
								<div class="bank-account-label">{d.methodBankColones}</div>
								<code class="bank-num">{d.methodBankColonesNum}</code>
								<code class="bank-iban">{d.methodBankColonesIban}</code>
							</div>
							<div class="bank-account">
								<div class="bank-account-label">{d.methodBankDollars}</div>
								<code class="bank-num">{d.methodBankDollarsNum}</code>
								<code class="bank-iban">{d.methodBankDollarsIban}</code>
							</div>
						</div>
					</article>
				</div>
			</div>
		</section>
	</div>

	<!-- ─── IMPORTANT ────────────────────────────────────────── -->
	<section class="section important-section" aria-labelledby="important-heading">
		<div class="important-ambient" aria-hidden="true"></div>
		<div class="container important-container">
			<div class="important-box reveal reveal-scale">
				<div class="important-box-shine" aria-hidden="true"></div>
				<div class="important-box-inner">
					<header class="important-header">
						<div class="important-icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<circle cx="12" cy="12" r="10"/>
								<line x1="12" y1="8" x2="12" y2="12"/>
								<line x1="12" y1="16" x2="12.01" y2="16"/>
							</svg>
						</div>
						<div class="important-heading-block">
							<h2 id="important-heading" class="important-title">{d.importantTitle}</h2>
							<div class="important-title-rule" aria-hidden="true"></div>
						</div>
					</header>

					<p class="important-intro reveal reveal-d1">{d.importantIntro}</p>

					<div class="important-form-note reveal reveal-d2">
						<div class="important-form-note-icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.55" stroke-linecap="round" stroke-linejoin="round">
								<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
								<polyline points="14 2 14 8 20 8"/>
								<line x1="16" y1="13" x2="8" y2="13"/>
								<line x1="16" y1="17" x2="8" y2="17"/>
							</svg>
						</div>
						<div class="important-form-note-copy">
							<p>{d.importantFormNote}</p>
						</div>
						<a
							class="btn btn-primary important-form-btn"
							href={d.importantFormLink}
							target="_blank"
							rel="noopener noreferrer"
						>
							{d.importantFormBtn}
							<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="important-form-btn-arrow" aria-hidden="true">
								<path d="M3 8h10M9 4l4 4-4 4"/>
							</svg>
						</a>
					</div>

					<ol class="important-steps">
						<li class="important-step reveal reveal-d1">
							<span class="step-num">1</span>
							<div class="important-step-body">
								<p class="important-step-text">{d.importantStep1}</p>
							</div>
						</li>
						<li class="important-step reveal reveal-d2">
							<span class="step-num">2</span>
							<div class="important-step-body">
								<p class="important-step-text">{d.importantStep2}</p>
								<div class="important-contact-grid">
									<div class="important-contact-item">
										<span class="important-contact-label">{d.importantContactEmailLabel}</span>
										<a href={`mailto:${d.importantStep2Email}`}>{d.importantStep2Email}</a>
									</div>
									<div class="important-contact-item">
										<span class="important-contact-label">{d.importantContactWhatsappLabel}</span>
										<a href={`https://wa.me/${d.importantStep2Whatsapp.replace(/\s+/g, '')}`}>
											{d.importantStep2Whatsapp}
										</a>
									</div>
								</div>
							</div>
						</li>
						<li class="important-step reveal reveal-d3">
							<span class="step-num">3</span>
							<div class="important-step-body">
								<p class="important-step-text">{d.importantStep3}</p>
							</div>
						</li>
						<li class="important-step reveal reveal-d4">
							<span class="step-num">4</span>
							<div class="important-step-body">
								<p class="important-step-text">{d.importantStep4}</p>
							</div>
						</li>
					</ol>
				</div>
			</div>
		</div>
	</section>

</main>

<style>
	/* ── Intro hero — Mobile First ─────────────────────────── */
	.donate-intro-hero {
		position: relative;
		background: linear-gradient(165deg, #f3f6fd 0%, #ffffff 42%, #fafbfd 100%);
		overflow: hidden;
	}

	.donate-intro-hero-accent {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 4px;
		background: linear-gradient(90deg, var(--color-accent) 0%, var(--color-primary) 55%, rgba(0, 32, 91, 0.15) 100%);
	}

	.donate-intro-hero-inner {
		display: grid;
		grid-template-columns: 1fr;
		gap: 36px;
		align-items: start;
		padding-top: 8px;
		padding-bottom: 8px;
	}

	@media (min-width: 960px) {
		.donate-intro-hero-inner {
			grid-template-columns: 1.05fr 0.95fr;
			gap: 48px 56px;
			align-items: center;
		}
	}

	.donate-intro-copy {
		max-width: 640px;
	}

	.donate-intro-kicker-row {
		margin-bottom: 6px;
	}

	.donate-intro-title {
		margin: 0 0 14px;
		font-size: clamp(2rem, 4.5vw, 2.75rem);
		font-weight: 900;
		letter-spacing: -0.03em;
		line-height: 1.12;
		color: var(--color-base);
	}

	.donate-intro-lead {
		margin: 0 0 22px;
		font-size: clamp(1.05rem, 1.35vw, 1.2rem);
		line-height: 1.58;
		font-weight: 600;
		color: var(--color-text);
		max-width: 52ch;
	}

	/* Funding context — same narrative weight as the lead; not “muted fine print” */
	.donate-intro-funding {
		margin: 0 0 14px;
		padding: 20px 22px 22px;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.95) 0%, rgba(243, 248, 255, 0.88) 100%);
		border: 1px solid rgba(0, 32, 91, 0.1);
		border-left: 4px solid var(--color-primary);
		border-radius: 16px;
		box-shadow: 0 10px 32px rgba(0, 32, 91, 0.07);
	}

	.donate-intro-body {
		margin: 0;
		font-size: clamp(1.02rem, 1.25vw, 1.14rem);
		line-height: 1.72;
		font-weight: 700;
		color: var(--color-base);
		letter-spacing: -0.01em;
		max-width: none;
	}

	/* Supporters: 3 + 2 grid (reference layout) */
	.donate-intro-supporters {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: 1fr;
		gap: 10px;
	}

	@media (min-width: 520px) {
		.donate-intro-supporters {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	.donate-intro-supporter-card {
		display: flex;
		align-items: center;
		gap: 12px;
		padding: 12px 14px;
		border-radius: 14px;
		background: #fff;
		border: 1px solid rgba(0, 32, 91, 0.08);
		box-shadow: 0 4px 16px rgba(0, 32, 91, 0.05);
		transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
	}

	.donate-intro-supporter-card:hover {
		border-color: rgba(42, 118, 181, 0.35);
		box-shadow: 0 8px 24px rgba(0, 32, 91, 0.09);
		transform: translateY(-1px);
	}

	.donate-intro-supporter-icon {
		flex-shrink: 0;
		width: 44px;
		height: 44px;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(42, 118, 181, 0.16);
		border: 1px solid rgba(42, 118, 181, 0.22);
		transition: background 0.2s ease, border-color 0.2s ease;
	}

	.donate-intro-supporter-card:hover .donate-intro-supporter-icon {
		background: rgba(42, 118, 181, 0.22);
		border-color: rgba(42, 118, 181, 0.35);
	}

	/*
		Line-art SVGs load as black strokes; remap to --color-primary (#2a76b5)
		so icons match the rest of the UI (same idea as tinting a mono icon).
	*/
	.donate-intro-supporter-img {
		display: block;
		width: 22px;
		height: 22px;
		object-fit: contain;
		filter: brightness(0) saturate(100%) invert(40%) sepia(58%) saturate(520%) hue-rotate(169deg) brightness(0.96) contrast(0.96);
		transition: filter 0.2s ease, opacity 0.2s ease;
	}

	.donate-intro-supporter-card:hover .donate-intro-supporter-img {
