---
import logo2 from '../assets/logo-guardavidas-lettersonly.png';
import { copy, type Lang } from '../i18n/copy';
import { getRoutes } from '../i18n/routes';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const c = copy[lang];
const routes = getRoutes(lang);
---

<header class="site-header">
	<div class="container header-inner">

		<a class="brand" href={routes.home} aria-label={c.siteName}>
			<img src={logo2.src} alt={c.siteName} width="180" height="48" decoding="async" />
		</a>

	<!-- Primary nav — hidden on mobile, shown via JS toggle -->
	<nav class="nav" id="main-nav" aria-label={c.common.navAriaLabel}>
			<a href={routes.home}>{c.nav.home}</a>
			<a href={routes.donate}>{c.nav.donate}</a>
			<a href={routes.community}>{c.nav.community}</a>
			<a href={routes.contact}>{c.nav.contact}</a>
		</nav>

		<div class="header-end">
			<div class="lang-toggle" aria-label={c.common.language}>
				<a href={routes.langToggle.href}>{routes.langToggle.label}</a>
			</div>

			<!-- Hamburger — visible only on mobile -->
		<button
			class="nav-toggle"
			id="nav-toggle"
			aria-label={c.common.openMenu}
			data-label-open={c.common.openMenu}
			data-label-close={c.common.closeMenu}
			aria-expanded="false"
			aria-controls="main-nav"
		>
				<span class="bar"></span>
				<span class="bar"></span>
				<span class="bar"></span>
			</button>
		</div>

	</div>
</header>

<script>
	const toggle = document.getElementById('nav-toggle');
	const nav    = document.getElementById('main-nav');

	toggle?.addEventListener('click', () => {
		const isOpen = nav?.classList.toggle('is-open');
		toggle.setAttribute('aria-expanded', String(isOpen));
		const labelOpen  = toggle.dataset.labelOpen  ?? 'Open menu';
		const labelClose = toggle.dataset.labelClose ?? 'Close menu';
		toggle.setAttribute('aria-label', isOpen ? labelClose : labelOpen);
	});

	// Close on Escape
	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape' && nav?.classList.contains('is-open')) {
			nav.classList.remove('is-open');
			toggle?.setAttribute('aria-expanded', 'false');
			const labelOpen = toggle?.dataset.labelOpen ?? 'Open menu';
			toggle?.setAttribute('aria-label', labelOpen);
		}
	});

	// Close when tapping a nav link (useful on mobile SPA navigation)
	nav?.querySelectorAll('a').forEach((a) => {
		a.addEventListener('click', () => {
			nav.classList.remove('is-open');
			toggle?.setAttribute('aria-expanded', 'false');
		});
	});
</script>

<style>
	/* ── Header end (lang toggle + hamburger) ─────────────── */
	.header-end {
		display: flex;
		align-items: center;
		gap: 6px;
	}

	/* ── Hamburger button ─────────────────────────────────── */
	.nav-toggle {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		width: 42px;
		height: 42px;
		background: rgba(255, 255, 255, 0.45);
		border: 1px solid rgba(255, 255, 255, 0.55);
		backdrop-filter: blur(10px) saturate(135%);
		-webkit-backdrop-filter: blur(10px) saturate(135%);
		border-radius: 10px;
		padding: 9px;
		cursor: pointer;
		transition:
			background 0.16s ease,
			border-color 0.16s ease,
			box-shadow 0.16s ease;
		flex-shrink: 0;
		box-shadow: 0 6px 20px rgba(0, 32, 91, 0.12);
	}

	.nav-toggle:hover {
		background: rgba(255, 255, 255, 0.62);
		border-color: rgba(255, 255, 255, 0.78);
	}

	.bar {
		display: block;
		width: 22px;
		height: 2px;
		background: var(--color-text);
		border-radius: 2px;
		transition: transform 0.22s ease, opacity 0.22s ease;
	}

	/* X animation when open */
	.nav-toggle[aria-expanded="true"] .bar:nth-child(1) {
		transform: translateY(7px) rotate(45deg);
	}
	.nav-toggle[aria-expanded="true"] .bar:nth-child(2) {
		opacity: 0;
		transform: scaleX(0);
	}
	.nav-toggle[aria-expanded="true"] .bar:nth-child(3) {
		transform: translateY(-7px) rotate(-45deg);
	}

	/* ── Mobile nav: dropdown (hidden by default) ─────────── */
	.nav {
		display: none;
		position: absolute;
		top: 100%;
		left: 0;
		right: 0;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.74), rgba(250, 253, 255, 0.68));
		backdrop-filter: blur(18px) saturate(145%);
		-webkit-backdrop-filter: blur(18px) saturate(145%);
		border-bottom: 1px solid rgba(255, 255, 255, 0.45);
		box-shadow: 0 20px 34px rgba(0, 24, 74, 0.15);
		flex-direction: column;
		padding: 10px 16px 18px;
		gap: 2px;
		z-index: 100;
	}

	.nav.is-open {
		display: flex;
	}

	/* Larger touch targets for mobile links */
	.nav a {
		padding: 11px 10px;
		border-radius: 8px;
		font-size: 15px;
		transition: background 0.1s;
	}

	.nav a:hover {
		background: rgba(0, 32, 91, 0.06);
	}

	/* ── Desktop: inline nav, hide hamburger ──────────────── */
	@media (min-width: 640px) {
		.nav {
			display: flex;
			position: static;
			background: none;
			backdrop-filter: none;
			-webkit-backdrop-filter: none;
			border: none;
			box-shadow: none;
			flex-direction: row;
			padding: 0;
			gap: 4px;
			z-index: auto;
		}

		/* Restore compact desktop link style */
		.nav a {
			padding: 8px 10px;
			font-size: 13px;
		}

		.nav-toggle {
			display: none;
		}
	}
</style>
