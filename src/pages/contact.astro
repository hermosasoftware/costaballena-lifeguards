---
import { copy, type Lang } from '../i18n/copy';
import SiteLayout from '../layouts/SiteLayout.astro';

const lang: Lang = 'en';
const c = copy[lang];
---

<SiteLayout lang={lang} title={c.pages.contactTitle}>
    <main class="page">
        <div class="container" style="max-width: 820px;">
            <h1>{c.pages.contactTitle}</h1>
            <p class="muted" style="line-height: 1.8; font-weight: 600;">
                {c.pages.contactBody}
            </p>
        </div>
    </main>
</SiteLayout>

